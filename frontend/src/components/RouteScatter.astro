---
import routeGeoText from '@data/routes.geojson?raw';

interface RouteProps {
  origin: string; dest: string; dest_city: string;
  late_rate: number; flight_freq: number; mean_delay: number;
  mean_fare: number; mean_distance: number; kmeans: number;
}
interface Feature { properties: RouteProps }
interface GeoJSON  { features: Feature[] }

const geo: GeoJSON = JSON.parse(routeGeoText);
const maxFreq = Math.max(...geo.features.map(f => f.properties.flight_freq));

interface RoutePoint {
  x: number; y: number; r: number;
  origin: string; dest: string; destCity: string;
  freq: number; fare: number; delay: number;
}

const routes: RoutePoint[] = geo.features.map(f => {
  const p = f.properties;
  return {
    x:        Math.round(p.mean_distance),
    y:        parseFloat((p.late_rate * 100).toFixed(1)),
    r:        Math.max(3, Math.round(3 + Math.sqrt(p.flight_freq / maxFreq) * 9)),
    origin:   p.origin,
    dest:     p.dest,
    destCity: p.dest_city ?? '',
    freq:     p.flight_freq,
    fare:     Math.round(p.mean_fare),
    delay:    Math.round(p.mean_delay),
  };
});

const routesJSON = JSON.stringify(routes);
---

<div class="scatter-wrap">
  <div class="filter-row" role="group" aria-label="Filter by airport">
    {['All','IAD','DCA','BWI'].map(ap => (
      <button class={`filter-btn${ap === 'All' ? ' active' : ''}`} data-filter={ap}>{ap}</button>
    ))}
    <span class="filter-hint muted">bubble size = flight volume</span>
  </div>
  <div class="chart-container">
    <canvas id="route-scatter" data-routes={routesJSON}></canvas>
  </div>
</div>

<script>
import { Chart, BubbleController, LinearScale, PointElement, Tooltip, Legend } from 'chart.js';
Chart.register(BubbleController, LinearScale, PointElement, Tooltip, Legend);

interface RoutePoint {
  x: number; y: number; r: number;
  origin: string; dest: string; destCity: string;
  freq: number; fare: number; delay: number;
}

const canvas  = document.getElementById('route-scatter') as HTMLCanvasElement;
const allData = JSON.parse(canvas.dataset.routes!) as RoutePoint[];

const AP_COLOR: Record<string, string> = {
  IAD: '78,154,241',
  DCA: '249,115,22',
  BWI: '34,197,94',
};

function buildDatasets(filter: string) {
  const filtered = filter === 'All' ? allData : allData.filter(d => d.origin === filter);
  const byAp: Record<string, RoutePoint[]> = {};
  for (const d of filtered) {
    (byAp[d.origin] ??= []).push(d);
  }
  return Object.entries(byAp).map(([ap, pts]) => ({
    label:           ap,
    data:            pts,
    backgroundColor: `rgba(${AP_COLOR[ap] ?? '255,255,255'},0.65)`,
    borderColor:     `rgba(${AP_COLOR[ap] ?? '255,255,255'},0.9)`,
    borderWidth:     1,
    hoverBorderWidth: 2,
  }));
}

const chart = new Chart(canvas, {
  type: 'bubble',
  data: { datasets: buildDatasets('All') },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    animation: { duration: 250 },
    plugins: {
      legend: {
        labels: { color: '#888', boxWidth: 10, padding: 16, font: { size: 11 } },
      },
      tooltip: {
        backgroundColor: 'rgba(15,17,23,0.95)',
        titleColor:      '#e8e8e8',
        bodyColor:       '#aaa',
        borderColor:     '#2a2d3a',
        borderWidth:     1,
        padding:         10,
        callbacks: {
          title(items) {
            const d = items[0].raw as RoutePoint;
            const city = d.destCity ? ` (${d.destCity})` : '';
            return `${d.origin} → ${d.dest}${city}`;
          },
          label(item) {
            const d = item.raw as RoutePoint;
            return [
              `Late rate:  ${d.y.toFixed(1)}%`,
              `Avg delay:  +${d.delay} min`,
              `Distance:   ${d.x.toLocaleString()} mi`,
              `Avg fare:   $${d.fare}`,
              `Flights:    ${d.freq.toLocaleString()}`,
            ];
          },
        },
      },
    },
    scales: {
      x: {
        type: 'linear',
        title: { display: true, text: 'Distance (mi)', color: '#888', font: { size: 11 } },
        ticks: { color: '#888', font: { size: 11 } },
        grid:  { color: '#2a2d3a' },
        border: { color: '#2a2d3a' },
      },
      y: {
        title: { display: true, text: 'Late rate (%)', color: '#888', font: { size: 11 } },
        ticks: {
          color: '#888',
          font: { size: 11 },
          callback: (v: unknown) => `${v}%`,
        },
        grid:  { color: '#2a2d3a' },
        border: { color: '#2a2d3a' },
        min: 0,
      },
    },
  },
});

// Filter buttons
document.querySelectorAll<HTMLButtonElement>('.scatter-wrap .filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.scatter-wrap .filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    chart.data.datasets = buildDatasets(btn.dataset.filter!);
    chart.update();
  });
});
</script>

<style>
  .scatter-wrap { margin-top: 1.75rem; }

  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .filter-btn {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    color: var(--muted);
    border-radius: 6px;
    padding: 0.28rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .filter-btn.active { border-color: #e8e8e8; color: #e8e8e8; }
  .filter-hint { font-size: 0.72rem; margin-left: 0.5rem; }

  .chart-container {
    position: relative;
    height: 360px;
    background: var(--surface);
    border-radius: 10px;
    border: 1px solid #2a2d3a;
    padding: 1rem;
  }

  @media (max-width: 640px) {
    .chart-container { height: 280px; padding: 0.75rem; }
    .filter-hint { display: none; }
  }
</style>
