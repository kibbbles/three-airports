---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="cfd" data-base={base}>
  <div class="cfd-header">
    <div id="cfd-ap" role="group" aria-label="Filter by airport">
      <button class="cfd-apbtn active" data-ap="-1">All</button>
      <button class="cfd-apbtn iad"    data-ap="0">IAD</button>
      <button class="cfd-apbtn dca"    data-ap="1">DCA</button>
      <button class="cfd-apbtn bwi"    data-ap="2">BWI</button>
    </div>
    <p class="cfd-count"><span id="cfd-n">loading…</span> flights selected</p>
  </div>

  <div class="cfd-grid">
    <figure class="cfd-panel">
      <figcaption>Hour of Day <em>— drag to filter</em></figcaption>
      <svg id="cfd-hour"  class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Arrival Delay (minutes) <em>— click to toggle</em></figcaption>
      <svg id="cfd-delay" class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Month <em>— drag to filter</em></figcaption>
      <svg id="cfd-month" class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Distance (miles) <em>— click to toggle</em></figcaption>
      <svg id="cfd-dist"  class="cfd-svg"></svg>
    </figure>
  </div>
</div>

<script>
import {
  select, scaleLinear, scaleBand, brushX,
  axisBottom, axisLeft, max as d3max,
} from 'd3';
import type { BrushBehavior, ScaleBand, ScaleLinear, Selection } from 'd3';

// ── types ─────────────────────────────────────────────────────────
interface CFData { airports: string[]; rows: number[][]; }

// ── load data ──────────────────────────────────────────────────────
const mount = document.getElementById('cfd') as HTMLElement;
const base  = mount.dataset.base ?? '';
const cfData: CFData = await fetch(`${base}/data/crossfilter_data.json`).then(r => r.json());
const rows = cfData.rows;

// Column offsets
const DB = 7;   // delay bins  db0..db5 at 7..12
const XB = 13;  // dist  bins  xb0..xb5 at 13..18

// ── state ──────────────────────────────────────────────────────────
const state = {
  ap:         -1,
  hourRange:  [0, 23] as [number, number],
  monthRange: [1, 12] as [number, number],
  delayMask:  0x3F,   // bits 0-5 all on
  distMask:   0x3F,
};

// ── colours ────────────────────────────────────────────────────────
const AP_COLORS = ['#4e9af1', '#f97316', '#22c55e'];
const accent = () => state.ap >= 0 ? AP_COLORS[state.ap] : '#4e9af1';

// ── crossfilter compute ────────────────────────────────────────────
function compute() {
  const hBg = new Float64Array(24), hFg = new Float64Array(24);
  const mBg = new Float64Array(12), mFg = new Float64Array(12);
  const dBg = new Float64Array(6),  dFg = new Float64Array(6);
  const xBg = new Float64Array(6),  xFg = new Float64Array(6);
  let total = 0;

  for (const r of rows) {
    const o = r[0], m = r[2], h = r[3];
    if (state.ap >= 0 && o !== state.ap) continue;

    let dN = 0, xN = 0;
    for (let i = 0; i < 6; i++) {
      if (state.delayMask & (1 << i)) dN += r[DB + i];
      if (state.distMask  & (1 << i)) xN += r[XB + i];
    }

    const pM = m >= state.monthRange[0] && m <= state.monthRange[1];
    const pH = h >= state.hourRange[0]  && h <= state.hourRange[1];
    const pD = dN > 0;
    const pX = xN > 0;

    // background: airport filter only (total operated in cell)
    const opN = r[DB]+r[DB+1]+r[DB+2]+r[DB+3]+r[DB+4]+r[DB+5];
    hBg[h]   += opN;
    mBg[m-1] += opN;
    for (let i = 0; i < 6; i++) { dBg[i] += r[DB+i]; xBg[i] += r[XB+i]; }

    // foreground: all filters except own chart
    if (pM && pD && pX) hFg[h]   += dN;
    if (pH && pD && pX) mFg[m-1] += dN;
    if (pM && pH && pX) for (let i = 0; i < 6; i++) dFg[i] += r[DB+i];
    if (pM && pH && pD) for (let i = 0; i < 6; i++) xFg[i] += r[XB+i];
    if (pM && pH && pD && pX) total += dN;
  }
  return { hBg, hFg, mBg, mFg, dBg, dFg, xBg, xFg, total };
}

// ── chart layout ───────────────────────────────────────────────────
const PAD = { t: 6, r: 8, b: 30, l: 40 };

interface ChartContext {
  g:     Selection<SVGGElement, unknown, null, undefined>;
  xSc:   ScaleBand<string>;
  ySc:   ScaleLinear<number, number>;
  cW:    number;
  cH:    number;
}

function dims(svgEl: SVGSVGElement) {
  // Read from the figure parent (HTML element — reliable clientWidth) rather than the SVG itself.
  // SVG getBoundingClientRect() returns 0 until the browser has finished layout.
  const panel = svgEl.closest('figure') as HTMLElement | null;
  const panelW = panel ? panel.getBoundingClientRect().width : 0;
  const W = Math.max(panelW - 28, 200); // 28 ≈ 2 × 0.85rem padding
  const H = 145;
  return { W, H, cW: W - PAD.l - PAD.r, cH: H - PAD.t - PAD.b };
}

// ── brush chart init ───────────────────────────────────────────────
interface BrushChart {
  svgEl:   SVGSVGElement;
  labels:  string[];
  brush:   BrushBehavior<unknown>;
  ctx?:    ChartContext;
}

function initBrushChart(
  svgEl: SVGSVGElement,
  labels: string[],
  onBrush: (lo: number, hi: number) => void,
): BrushChart {
  const svg = select(svgEl);
  const { W, H, cW, cH } = dims(svgEl);
  svg.attr('width', W).attr('height', H);

  const g = svg.append('g').attr('class', 'bars').attr('transform', `translate(${PAD.l},${PAD.t})`);
  const brushG = svg.append('g').attr('class', 'brush').attr('transform', `translate(${PAD.l},${PAD.t})`);

  const xSc = scaleBand().domain(labels).range([0, cW]).padding(labels.length > 14 ? 0.08 : 0.15);
  const ySc = scaleLinear().range([cH, 0]);

  // Axes (appended once)
  const xTickFn = (ax: ReturnType<typeof axisBottom>) => {
    if (labels.length > 14) ax.tickValues(labels.filter((_, i) => i % 4 === 0));
    return ax;
  };
  g.append('g').attr('class', 'x-ax').attr('transform', `translate(0,${cH})`)
    .call(xTickFn(axisBottom(xSc).tickSize(0)))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '0.9em'); });

  g.append('g').attr('class', 'y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  // Brush
  const brush = brushX<unknown>()
    .extent([[0, 0], [cW, cH]])
    .on('end', (event) => {
      if (!event.selection) {
        // Clear brush = reset to full range
        const lo = 0, hi = labels.length - 1;
        onBrush(lo, hi);
        return;
      }
      const [px0, px1] = event.selection as [number, number];
      const step = xSc.step();
      const lo = Math.max(0, Math.floor(px0 / step));
      const hi = Math.min(labels.length - 1, Math.ceil(px1 / step) - 1);
      onBrush(Math.min(lo, hi), Math.max(lo, hi));
    });
  brushG.call(brush);
  brushG.select('.selection').attr('fill', '#4e9af130').attr('stroke', 'none');
  brushG.select('.overlay').attr('fill', 'transparent');

  return { svgEl, labels, brush, ctx: { g, xSc, ySc, cW, cH } };
}

// ── toggle chart init ──────────────────────────────────────────────
interface ToggleChart {
  svgEl:  SVGSVGElement;
  labels: string[];
  maskKey: 'delayMask' | 'distMask';
  ctx?:   ChartContext;
}

function initToggleChart(
  svgEl: SVGSVGElement,
  labels: string[],
  maskKey: 'delayMask' | 'distMask',
): ToggleChart {
  const svg = select(svgEl);
  const { W, H, cW, cH } = dims(svgEl);
  svg.attr('width', W).attr('height', H);

  const g = svg.append('g').attr('class', 'bars').attr('transform', `translate(${PAD.l},${PAD.t})`);
  const xSc = scaleBand().domain(labels).range([0, cW]).padding(0.25);
  const ySc = scaleLinear().range([cH, 0]);

  g.append('g').attr('class', 'x-ax').attr('transform', `translate(0,${cH})`)
    .call(axisBottom(xSc).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '0.9em'); });

  g.append('g').attr('class', 'y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  return { svgEl, labels, maskKey, ctx: { g, xSc, ySc, cW, cH } };
}

// ── update bars (shared) ────────────────────────────────────────────
function updateBars(
  ctx: ChartContext,
  bg: Float64Array, fg: Float64Array,
  maskKey?: 'delayMask' | 'distMask',
) {
  const { g, xSc, ySc, cW, cH } = ctx;
  const labels = xSc.domain();
  const yMax   = Math.max(d3max(bg) ?? 0, 1);
  ySc.domain([0, yMax]).nice();

  // Update y-axis
  g.select<SVGGElement>('g.y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  // Grid
  g.selectAll<SVGLineElement, number>('line.grid')
    .data(ySc.ticks(3))
    .join('line').attr('class', 'grid')
    .attr('x1', 0).attr('x2', cW)
    .attr('y1', d => ySc(d)).attr('y2', d => ySc(d))
    .attr('stroke', '#1a1d2a').attr('stroke-width', 1)
    .lower();

  type D = { v: number; i: number };
  const bgData: D[] = Array.from(bg, (v, i) => ({ v, i }));
  const fgData: D[] = Array.from(fg, (v, i) => ({ v, i }));
  const col = accent();

  // BG bars
  g.selectAll<SVGRectElement, D>('rect.bg')
    .data(bgData, d => String(d.i))
    .join('rect').attr('class', 'bg')
    .attr('x', d => xSc(labels[d.i])!)
    .attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth())
    .attr('height', d => cH - ySc(d.v))
    .attr('fill', '#1e2132')
    .style('cursor', maskKey ? 'pointer' : 'default');

  // FG bars
  g.selectAll<SVGRectElement, D>('rect.fg')
    .data(fgData, d => String(d.i))
    .join('rect').attr('class', 'fg')
    .attr('x', d => xSc(labels[d.i])!)
    .attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth())
    .attr('height', d => cH - ySc(d.v))
    .attr('fill', d => maskKey
      ? (state[maskKey] & (1 << d.i)) ? col : '#2a2d3a'
      : col)
    .attr('opacity', 0.88)
    .style('cursor', maskKey ? 'pointer' : 'default');

  if (maskKey) {
    const key = maskKey;
    g.selectAll<SVGRectElement, D>('rect.fg, rect.bg')
      .on('click', (_, d) => { state[key] ^= (1 << d.i); render(); });
  }
}

// ── labels ─────────────────────────────────────────────────────────
const HOUR_LABELS  = Array.from({length: 24}, (_, i) => String(i));
const MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DELAY_LABELS = ['early','0–14','15–29','30–59','1–2h','2h+'];
const DIST_LABELS  = ['<300','300–','600–','1k–','1.5k–','2.5k+'];

// ── chart holders ──────────────────────────────────────────────────
let hourChart:  ReturnType<typeof initBrushChart>  | null = null;
let monthChart: ReturnType<typeof initBrushChart>  | null = null;
let delayChart: ReturnType<typeof initToggleChart> | null = null;
let distChart:  ReturnType<typeof initToggleChart> | null = null;

// ── render ─────────────────────────────────────────────────────────
function render() {
  if (!hourChart || !monthChart || !delayChart || !distChart) return;
  const { hBg, hFg, mBg, mFg, dBg, dFg, xBg, xFg, total } = compute();
  updateBars(hourChart.ctx!,  hBg, hFg);
  updateBars(monthChart.ctx!, mBg, mFg);
  updateBars(delayChart.ctx!, dBg, dFg, 'delayMask');
  updateBars(distChart.ctx!,  xBg, xFg, 'distMask');
  document.getElementById('cfd-n')!.textContent = total.toLocaleString();
}

// ── init all charts (called once container has a real width) ───────
function initCharts() {
  hourChart  = initBrushChart(
    document.getElementById('cfd-hour')  as SVGSVGElement, HOUR_LABELS,
    (lo, hi) => { state.hourRange  = [lo, hi]; render(); },
  );
  monthChart = initBrushChart(
    document.getElementById('cfd-month') as SVGSVGElement, MONTH_LABELS,
    (lo, hi) => { state.monthRange = [lo + 1, hi + 1]; render(); },
  );
  delayChart = initToggleChart(
    document.getElementById('cfd-delay') as SVGSVGElement, DELAY_LABELS, 'delayMask',
  );
  distChart  = initToggleChart(
    document.getElementById('cfd-dist')  as SVGSVGElement, DIST_LABELS,  'distMask',
  );
  render();
}

// Wait until the container has a painted width before initialising D3.
// getBoundingClientRect on SVG returns 0 until layout is complete.
const cfdEl = document.getElementById('cfd') as HTMLElement;
const ro = new ResizeObserver((entries) => {
  if (entries[0].contentRect.width > 0) {
    ro.disconnect();
    initCharts();
  }
});
ro.observe(cfdEl);
// Immediate fallback — works when the element already has a width (e.g. cached page).
if (cfdEl.getBoundingClientRect().width > 0) {
  ro.disconnect();
  initCharts();
}

// ── airport buttons ────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('#cfd-ap .cfd-apbtn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#cfd-ap .cfd-apbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.ap = parseInt(btn.dataset.ap!);
    render();
  });
});
</script>

<style>
  #cfd { margin-top: 1.75rem; }

  /* ── Header row ── */
  .cfd-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.1rem;
    flex-wrap: wrap;
  }
  #cfd-ap {
    display: flex;
    gap: 0.4rem;
  }
  .cfd-apbtn {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    color: var(--muted);
    border-radius: 6px;
    padding: 0.28rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .cfd-apbtn.active         { border-color: #e8e8e8; color: #e8e8e8; }
  .cfd-apbtn.iad.active     { border-color: #4e9af1; color: #4e9af1; }
  .cfd-apbtn.dca.active     { border-color: #f97316; color: #f97316; }
  .cfd-apbtn.bwi.active     { border-color: #22c55e; color: #22c55e; }

  .cfd-count {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
  }
  #cfd-n { color: #e8e8e8; font-weight: 600; }

  /* ── 2×2 grid ── */
  .cfd-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 640px) {
    .cfd-grid { grid-template-columns: 1fr; }
  }

  .cfd-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.85rem 0.85rem 0.5rem;
    margin: 0;
  }
  .cfd-panel figcaption {
    font-size: 0.78rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 0.5rem;
    letter-spacing: 0.01em;
  }
  .cfd-panel figcaption em {
    font-style: normal;
    font-weight: 400;
    color: #555;
  }
  .cfd-svg {
    display: block;
    width: 100%;
    height: 145px;
  }
  @media (max-width: 640px) {
    .cfd-svg { height: 115px; }
  }

  /* D3 brush handle — remove default resize handles for cleaner look */
  :global(.brush .handle) { display: none; }
  :global(.brush .selection) {
    fill: rgba(78,154,241,0.12) !important;
    stroke: rgba(78,154,241,0.35) !important;
    stroke-width: 1px !important;
  }
</style>
