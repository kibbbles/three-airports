---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="cfd" data-base={base}>
  <div class="cfd-header">
    <div id="cfd-ap" role="group" aria-label="Filter by airport">
      <button class="cfd-apbtn active" data-ap="-1">All</button>
      <button class="cfd-apbtn iad"    data-ap="0">IAD</button>
      <button class="cfd-apbtn dca"    data-ap="1">DCA</button>
      <button class="cfd-apbtn bwi"    data-ap="2">BWI</button>
    </div>
    <button id="cfd-reset" class="cfd-reset">reset filters</button>
    <p class="cfd-count"><span id="cfd-n">loading…</span> flights selected</p>
  </div>

  <div class="cfd-grid">
    <figure class="cfd-panel">
      <figcaption>Hour of Day <em>— drag to filter</em></figcaption>
      <svg id="cfd-hour"  class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Arrival Delay (minutes) <em>— drag to filter</em></figcaption>
      <svg id="cfd-delay" class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Distance (miles) <em>— drag to filter</em></figcaption>
      <svg id="cfd-dist"  class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel cfd-wide">
      <figcaption>Date <em>— drag to filter</em></figcaption>
      <svg id="cfd-date" class="cfd-svg"></svg>
    </figure>
  </div>

  <aside id="cfd-totals">
    <div class="cfd-summary">
      <div id="cfd-date-label" class="cfd-date-label">Jan '15 – Jan '26</div>
      <span><span id="cfd-list-count">—</span> routes.</span>
    </div>
    <span class="cfd-totals-note" id="cfd-totals-note">Table filters by airport, date, hour, and distance. Selecting a delay range re-sorts by late rate — most delayed routes first.</span>
  </aside>

  <div id="cfd-list">
    <table id="cfd-table">
      <thead>
        <tr>
          <th class="col-route  sortable" data-col="route">Route</th>
          <th class="col-dest   sortable" data-col="dest">Destination</th>
          <th class="col-flights sortable sort-desc" data-col="n" title="Flights in the selected date range">Flights</th>
          <th class="col-late   sortable" data-col="lr">Late rate</th>
          <th class="col-delay  sortable" data-col="md" title="Mean ArrDelay for all operated flights in the selected date window — not filtered by the delay brush">Avg delay</th>
          <th class="col-fare   sortable" data-col="mf">Avg fare</th>
          <th class="col-dist   sortable" data-col="dist">Distance</th>
          <th class="col-airlines">Airlines</th>
        </tr>
      </thead>
      <tbody id="cfd-tbody">
        <tr><td colspan="8" class="loading-row">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
import {
  select, scaleLinear, scaleBand, brushX,
  axisBottom, axisLeft, max as d3max,
} from 'd3';
import type { ScaleBand, ScaleLinear, Selection } from 'd3';

// ── types ──────────────────────────────────────────────────────────
interface CFData { airports: string[]; rows: number[][]; }
interface RMData {
  origins: string[]; dests: string[];
  carriers: Record<string, string[]>;
  route_hours: Record<string, number[]>;
  delay_dist:  Record<string, { n: number[]; s: number[] }>;
  cols: string[];
  rows: (number | null)[][];
}
interface RouteProps {
  origin: string; dest: string; dest_city: string;
  late_rate: number; flight_freq: number; mean_delay: number;
  mean_fare: number; mean_distance: number;
}
interface AggStats {
  n: number; lateRate: number;
  meanDelay: number | null; meanFare: number | null;
}

// ── load data ──────────────────────────────────────────────────────
const mount = document.getElementById('cfd') as HTMLElement;
const base  = mount.dataset.base ?? '';

const [cfData, routeGeo, rmData] = await Promise.all([
  fetch(`${base}/data/crossfilter_data.json`).then(r => r.json()) as Promise<CFData>,
  fetch(`${base}/data/routes.geojson`).then(r => r.json()),
  fetch(`${base}/data/route_monthly.json`)
    .then(r => r.ok ? r.json() as Promise<RMData> : null)
    .catch(() => null),
]);

const rows   = cfData.rows;
const routes: RouteProps[] = routeGeo.features.map((f: any) => f.properties);

const DB   = 7;   // row offset for delay bins
const DB_N = 14;  // number of delay bins
const XB   = 21;  // row offset for dist bins (7 + 14)
const XB_N = 15;  // number of dist bins (even 200-mi steps)

// ── state ──────────────────────────────────────────────────────────
const state = {
  ap:         -1,
  hourRange:  [0, 23]  as [number, number],
  dateRange:  [0, 132] as [number, number],
  delayRange: [0, 13]  as [number, number],
  distRange:  [0, 14]  as [number, number],
};

// ── sort state ─────────────────────────────────────────────────────
let sortCol = 'n';     // column key
let sortDir = -1 as 1 | -1;  // -1 = desc, 1 = asc

// ── colours ────────────────────────────────────────────────────────
const AP_CODES  = ['IAD', 'DCA', 'BWI'];
const AP_COLORS = ['#4e9af1', '#f97316', '#22c55e'];
const ALL_COLOR = '#a78bfa';
const accent = () => state.ap >= 0 ? AP_COLORS[state.ap] : ALL_COLOR;

// ── carrier name lookup ────────────────────────────────────────────
const CARRIER_FULL: Record<string, string> = {
  '9E': 'Endeavor Air', 'AA': 'American',  'AS': 'Alaska',
  'B6': 'JetBlue',      'DL': 'Delta',     'EV': 'ExpressJet',
  'F9': 'Frontier',     'G4': 'Allegiant', 'MQ': 'Envoy Air',
  'NK': 'Spirit',       'OH': 'PSA',       'OO': 'SkyWest',
  'UA': 'United',       'US': 'US Airways','WN': 'Southwest',
  'YV': 'Mesa Air',     'YX': 'Republic',
};

// ── crossfilter compute ────────────────────────────────────────────
function compute() {
  const hBg    = new Float64Array(24),    hFg    = new Float64Array(24);
  const dateBg = new Float64Array(133),   dateFg = new Float64Array(133);
  const dBg    = new Float64Array(DB_N),  dFg    = new Float64Array(DB_N);
  const xBg    = new Float64Array(XB_N),  xFg    = new Float64Array(XB_N);
  let total = 0;

  for (const r of rows) {
    const o = r[0], yr = r[1], m = r[2], h = r[3];
    if (state.ap >= 0 && o !== state.ap) continue;

    const ymIdx = (yr - 2015) * 12 + (m - 1);

    let dN = 0;
    for (let i = 0; i < DB_N; i++) {
      if (i >= state.delayRange[0] && i <= state.delayRange[1]) dN += r[DB + i];
    }
    let xN = 0;
    for (let i = 0; i < XB_N; i++) {
      if (i >= state.distRange[0] && i <= state.distRange[1]) xN += r[XB + i];
    }

    const pM = ymIdx >= state.dateRange[0] && ymIdx <= state.dateRange[1];
    const pH = h >= state.hourRange[0] && h <= state.hourRange[1];
    const pD = dN > 0;
    const pX = xN > 0;

    let opN = 0;
    for (let i = 0; i < DB_N; i++) opN += r[DB + i];
    hBg[h]        += opN;
    dateBg[ymIdx] += opN;
    for (let i = 0; i < DB_N; i++) dBg[i] += r[DB + i];
    for (let i = 0; i < XB_N; i++) xBg[i] += r[XB + i];

    if (pM && pD && pX) hFg[h]        += dN;
    if (pH && pD && pX) dateFg[ymIdx] += dN;
    if (pM && pH && pX) for (let i = 0; i < DB_N; i++) dFg[i] += r[DB + i];
    if (pM && pH && pD) for (let i = 0; i < XB_N; i++) xFg[i] += r[XB + i];
    if (pM && pH && pD && pX) total += dN;
  }
  return { hBg, hFg, dateBg, dateFg, dBg, dFg, xBg, xFg, total };
}

// ── route stats aggregation (from route_monthly, date-aware) ───────
let _aggCache: Map<string, AggStats> | null = null;
let _aggCacheKey = '';

function getAggStats(): Map<string, AggStats> | null {
  if (!rmData) return null;
  const key = `${state.ap}|${state.dateRange[0]}|${state.dateRange[1]}`;
  if (key === _aggCacheKey) return _aggCache;

  type Acc = { n: number; lateN: number; dSum: number; dN: number; fSum: number; fN: number };
  const map = new Map<string, Acc>();
  const [lo, hi] = state.dateRange;

  for (const r of rmData.rows) {
    if (state.ap >= 0 && r[0] !== state.ap) continue;
    const ymIdx = ((r[2] as number) - 2015) * 12 + ((r[3] as number) - 1);
    if (ymIdx < lo || ymIdx > hi) continue;

    const key2 = `${r[0]}-${r[1]}`;
    if (!map.has(key2)) map.set(key2, { n: 0, lateN: 0, dSum: 0, dN: 0, fSum: 0, fN: 0 });
    const acc = map.get(key2)!;
    const n   = r[4] as number;
    const lr  = r[5] as number;
    const md  = r[6] as number | null;
    const mf  = r[7] as number | null;
    acc.n     += n;
    acc.lateN += n * lr;
    if (md !== null) { acc.dSum += n * md; acc.dN += n; }
    if (mf !== null) { acc.fSum += n * mf; acc.fN += n; }
  }

  const result = new Map<string, AggStats>();
  for (const [k, acc] of map) {
    const [oi, di] = k.split('-').map(Number);
    const routeKey = `${rmData.origins[oi]}-${rmData.dests[di]}`;
    result.set(routeKey, {
      n:         acc.n,
      lateRate:  acc.n > 0 ? acc.lateN / acc.n : 0,
      meanDelay: acc.dN > 0 ? acc.dSum / acc.dN : null,
      meanFare:  acc.fN > 0 ? acc.fSum / acc.fN : null,
    });
  }

  _aggCache    = result;
  _aggCacheKey = key;
  return result;
}

// ── delay-brush-aware mean for a route ────────────────────────────
function getRouteDelayMean(routeKey: string): number | null {
  const delayActive = state.delayRange[0] !== 0 || state.delayRange[1] !== DB_N - 1;
  const agg = getAggStats();
  if (!delayActive || !rmData?.delay_dist) {
    return agg?.get(routeKey)?.meanDelay ?? null;
  }
  const dist = rmData.delay_dist[routeKey];
  if (!dist) return agg?.get(routeKey)?.meanDelay ?? null;
  let totalN = 0, totalS = 0;
  for (let i = state.delayRange[0]; i <= state.delayRange[1]; i++) {
    totalN += dist.n[i] ?? 0;
    totalS += dist.s[i] ?? 0;
  }
  return totalN > 0 ? totalS / totalN : null;
}

// ── route table filtering helpers ──────────────────────────────────
const DELAY_BIN_RANGES: [number, number][] = [
  [-Infinity, -60], [-60, -45], [-45, -30], [-30, -15], [-15, -5], [-5, 0],
  [0, 5], [5, 15], [15, 30], [30, 45], [45, 60], [60, 90], [90, 120], [120, Infinity],
];
const DIST_BIN_RANGES: [number, number][] = [
  [0, 200], [200, 400], [400, 600], [600, 800], [800, 1000],
  [1000, 1200], [1200, 1400], [1400, 1600], [1600, 1800], [1800, 2000],
  [2000, 2200], [2200, 2400], [2400, 2600], [2600, 2800], [2800, Infinity],
];

function inRange(value: number, range: [number, number], binRanges: [number, number][]) {
  if (range[0] === 0 && range[1] === binRanges.length - 1) return true;
  for (let i = range[0]; i <= range[1]; i++) {
    const [lo, hi] = binRanges[i];
    if (value >= lo && value < hi) return true;
  }
  return false;
}

// ── route list ─────────────────────────────────────────────────────
function updateList() {
  const apFilter  = state.ap >= 0 ? AP_CODES[state.ap] : null;
  const aggStats  = getAggStats();

  // Route table: airport + date (via aggStats) + hour + distance
  // Delay brush drives the histograms/count only — mean ArrDelay per route (~5–10 min)
  // never matches the tails of the distribution, so delay doesn't filter routes.
  const hourActive = state.hourRange[0] !== 0 || state.hourRange[1] !== 23;
  const rHours = rmData?.route_hours ?? {};

  let filtered = (apFilter ? routes.filter(r => r.origin === apFilter) : routes)
    .filter(r => {
      if (!hourActive) return true;
      const hrs = rHours[`${r.origin}-${r.dest}`];
      return !hrs || hrs.some(h => h >= state.hourRange[0] && h <= state.hourRange[1]);
    })
    .filter(r => inRange(r.mean_distance ?? 500, state.distRange, DIST_BIN_RANGES));

  // If we have time-filtered agg stats, only show routes with flights in that window
  if (aggStats) {
    filtered = filtered.filter(r => aggStats.has(`${r.origin}-${r.dest}`));
  }

  // Auto-sort: when delay brush selects late bins → late rate desc;
  //            when it selects early bins → mean delay asc (most negative first).
  //            User-clicked column always overrides.
  const delayActive = state.delayRange[0] !== 0 || state.delayRange[1] !== DB_N - 1;
  const earlyOnly   = delayActive && state.delayRange[1] <= 5;  // all bins < 0 min
  const effectiveCol = delayActive && sortCol === 'n' ? (earlyOnly ? 'md_asc' : 'lr') : sortCol;

  const sorted = [...filtered].sort((a, b) => {
    const as_ = aggStats?.get(`${a.origin}-${a.dest}`);
    const bs_ = aggStats?.get(`${b.origin}-${b.dest}`);
    switch (effectiveCol) {
      case 'route':  return sortDir * (`${a.origin}${a.dest}`).localeCompare(`${b.origin}${b.dest}`);
      case 'dest':   return sortDir * (a.dest_city || a.dest).localeCompare(b.dest_city || b.dest);
      case 'lr':     return sortDir * ((as_?.lateRate ?? a.late_rate) - (bs_?.lateRate ?? b.late_rate));
      case 'md':     return sortDir * ((getRouteDelayMean(`${a.origin}-${a.dest}`) ?? a.mean_delay ?? 0) - (getRouteDelayMean(`${b.origin}-${b.dest}`) ?? b.mean_delay ?? 0));
      case 'md_asc': return (getRouteDelayMean(`${a.origin}-${a.dest}`) ?? a.mean_delay ?? 0) - (getRouteDelayMean(`${b.origin}-${b.dest}`) ?? b.mean_delay ?? 0);
      case 'mf':     return sortDir * ((as_?.meanFare  ?? a.mean_fare  ?? 0) - (bs_?.meanFare  ?? b.mean_fare  ?? 0));
      case 'dist':   return sortDir * ((a.mean_distance ?? 0) - (b.mean_distance ?? 0));
      default:       return sortDir * ((as_?.n ?? a.flight_freq) - (bs_?.n ?? b.flight_freq));
    }
  });

  // Update sort indicators on headers
  document.querySelectorAll<HTMLElement>('#cfd-table th.sortable').forEach(th => {
    th.classList.remove('sort-asc', 'sort-desc');
    if (th.dataset.col === sortCol) th.classList.add(sortDir === -1 ? 'sort-desc' : 'sort-asc');
  });

  document.getElementById('cfd-list-count')!.textContent = String(sorted.length);

  const tbody = document.getElementById('cfd-tbody')!;
  tbody.innerHTML = sorted.map(r => {
    const rKey  = `${r.origin}-${r.dest}`;
    const stats = aggStats?.get(rKey);
    const col   = apFilter ? accent() : (AP_COLORS[AP_CODES.indexOf(r.origin)] ?? ALL_COLOR);
    const city  = r.dest_city || r.dest;

    const rKey2    = `${r.origin}-${r.dest}`;
    const lrVal    = stats?.lateRate  ?? r.late_rate;
    const nFlights = stats ? stats.n  : r.flight_freq;
    const mdVal    = getRouteDelayMean(rKey2) ?? r.mean_delay;
    const mfVal    = stats?.meanFare  ?? r.mean_fare;
    const distVal  = Math.round(r.mean_distance ?? 0);

    const late  = (lrVal * 100).toFixed(1);
    const pct   = Math.round(lrVal * 100);
    const delayRnd = Math.round(mdVal ?? 0);
    const delay = mdVal != null ? `${delayRnd > 0 ? '+' : ''}${delayRnd} min` : '—';
    const fare  = mfVal != null ? `$${Math.round(mfVal)}` : '—';

    const carriers    = rmData?.carriers[rKey2] ?? [];
    const carrierHtml = carriers.length
      ? carriers.map(c => CARRIER_FULL[c] ?? c).join(', ')
      : '—';
    const distStr = distVal > 0 ? `${distVal.toLocaleString()} mi` : '—';

    return `
      <tr>
        <td class="col-route"><span class="ap-dot" style="background:${col}"></span>${r.origin} → ${r.dest}</td>
        <td class="col-dest">${city}</td>
        <td class="col-flights">${nFlights.toLocaleString()}</td>
        <td class="col-late">
          <div class="late-bar-wrap">
            <div class="late-bar" style="width:${pct}%;background:${col}"></div>
          </div>
          <span class="late-pct">${late}%</span>
        </td>
        <td class="col-delay">${delay}</td>
        <td class="col-fare">${fare}</td>
        <td class="col-dist">${distStr}</td>
        <td class="col-airlines">${carrierHtml}</td>
      </tr>`;
  }).join('');
}

// ── chart layout ───────────────────────────────────────────────────
const PAD = { t: 6, r: 8, b: 30, l: 40 };

interface ChartContext {
  g:   Selection<SVGGElement, unknown, null, undefined>;
  xSc: ScaleBand<string>;
  ySc: ScaleLinear<number, number>;
  cW:  number; cH: number;
}

function dims(svgEl: SVGSVGElement) {
  const panel  = svgEl.closest('figure') as HTMLElement | null;
  const panelW = panel ? panel.getBoundingClientRect().width : 0;
  const W      = Math.max(panelW - 28, 200);
  return { W, H: 145, cW: W - PAD.l - PAD.r, cH: 145 - PAD.t - PAD.b };
}

// ── brush chart ────────────────────────────────────────────────────
function initBrushChart(
  svgEl: SVGSVGElement,
  labels: string[],
  onBrush: (lo: number, hi: number) => void,
  tickFilter?: (label: string, i: number) => boolean,
  tickSz = 0,
) {
  const svg = select(svgEl);
  const { W, H, cW, cH } = dims(svgEl);
  svg.attr('width', W).attr('height', H);

  const g      = svg.append('g').attr('class', 'bars').attr('transform', `translate(${PAD.l},${PAD.t})`);
  const brushG = svg.append('g').attr('class', 'brush').attr('transform', `translate(${PAD.l},${PAD.t})`);

  const xSc = scaleBand().domain(labels).range([0, cW]).padding(labels.length >= 14 ? 0.08 : 0.2);
  const ySc = scaleLinear().range([cH, 0]);

  const tickFn = (ax: ReturnType<typeof axisBottom>) => {
    if (tickFilter) ax.tickValues(labels.filter(tickFilter));
    return ax;
  };
  g.append('g').attr('class', 'x-ax').attr('transform', `translate(0,${cH})`)
    .call(tickFn(axisBottom(xSc).tickSize(tickSz)))
    .call(a => {
      a.select('.domain').remove();
      a.selectAll('line').attr('stroke', '#444').attr('y2', tickSz);
      a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', tickSz > 0 ? '1.4em' : '0.9em');
    });
  g.append('g').attr('class', 'y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  // ── decorative grip handles (pointer-events:none, visual only) ───
  const midY = cH / 2;
  const hh   = Math.min(cH - 6, 26);
  const gy   = midY - hh / 2;

  function makeGrip() {
    const hg = brushG.append('g').attr('visibility', 'hidden').attr('pointer-events', 'none');
    hg.append('rect')
      .attr('x', -5).attr('width', 10)
      .attr('y', gy).attr('height', hh)
      .attr('rx', 3)
      .attr('fill', 'rgba(225,225,232,0.93)')
      .attr('stroke', 'rgba(180,180,195,0.75)').attr('stroke-width', 0.75);
    for (const dy of [-4, 0, 4]) {
      hg.append('line')
        .attr('x1', -2.5).attr('x2', 2.5)
        .attr('y1', midY + dy).attr('y2', midY + dy)
        .attr('stroke', 'rgba(90,90,105,0.7)').attr('stroke-width', 1.25);
    }
    return hg;
  }

  const gripW = makeGrip();
  const gripE = makeGrip();

  function positionGrips(sel: [number, number] | null) {
    if (!sel) {
      gripW.attr('visibility', 'hidden');
      gripE.attr('visibility', 'hidden');
    } else {
      gripW.attr('visibility', 'visible').attr('transform', `translate(${sel[0]},0)`);
      gripE.attr('visibility', 'visible').attr('transform', `translate(${sel[1]},0)`);
    }
  }

  const brush = brushX<unknown>()
    .extent([[0, 0], [cW, cH]])
    .on('brush', (event) => {
      positionGrips(event.selection as [number, number] | null);
    })
    .on('end', (event) => {
      positionGrips(event.selection as [number, number] | null);
      if (!event.selection) { onBrush(0, labels.length - 1); return; }
      const [px0, px1] = event.selection as [number, number];
      const s = xSc.step();
      onBrush(
        Math.max(0, Math.floor(px0 / s)),
        Math.min(labels.length - 1, Math.ceil(px1 / s) - 1),
      );
    });

  brushG.call(brush);
  brushG.select('.overlay').attr('fill', 'transparent');

  function clear() {
    brushG.call(brush.move, null);
    positionGrips(null);
  }

  return { ctx: { g, xSc, ySc, cW, cH }, clear };
}

// ── update bars ────────────────────────────────────────────────────
function updateBars(ctx: ChartContext, bg: Float64Array, fg: Float64Array) {
  const { g, xSc, ySc, cW, cH } = ctx;
  const labels = xSc.domain();
  ySc.domain([0, Math.max(d3max(bg) ?? 0, 1)]).nice();

  g.select<SVGGElement>('g.y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  g.selectAll<SVGLineElement, number>('line.grid')
    .data(ySc.ticks(3)).join('line').attr('class', 'grid')
    .attr('x1', 0).attr('x2', cW)
    .attr('y1', d => ySc(d)).attr('y2', d => ySc(d))
    .attr('stroke', '#1a1d2a').attr('stroke-width', 1).lower();

  type D = { v: number; i: number };
  const bgData: D[] = Array.from(bg, (v, i) => ({ v, i }));
  const fgData: D[] = Array.from(fg, (v, i) => ({ v, i }));
  const col = accent();

  g.selectAll<SVGRectElement, D>('rect.bg')
    .data(bgData, d => String(d.i)).join('rect').attr('class', 'bg')
    .attr('x', d => xSc(labels[d.i])!).attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth()).attr('height', d => cH - ySc(d.v))
    .attr('fill', '#1e2132');

  g.selectAll<SVGRectElement, D>('rect.fg')
    .data(fgData, d => String(d.i)).join('rect').attr('class', 'fg')
    .attr('x', d => xSc(labels[d.i])!).attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth()).attr('height', d => cH - ySc(d.v))
    .attr('fill', col).attr('opacity', 0.88);
}

// ── labels ─────────────────────────────────────────────────────────
const HOUR_LABELS  = Array.from({length: 24}, (_, i) => String(i));
const DELAY_LABELS = ['<-60','-60','-45','-30','-15','-5','0','5','15','30','45','60','90','120+'];
const DIST_LABELS  = ['0','200','400','600','800','1k','1.2k','1.4k','1.6k','1.8k','2k','2.2k','2.4k','2.6k','2.8k+'];

const MN = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DATE_LABELS: string[] = [];
for (let y = 2015; y <= 2026; y++) {
  const end = y === 2026 ? 1 : 12;
  for (let mo = 1; mo <= end; mo++) DATE_LABELS.push(`${MN[mo-1]} '${String(y).slice(2)}`);
}

let hourChart:  ReturnType<typeof initBrushChart> | null = null;
let delayChart: ReturnType<typeof initBrushChart> | null = null;
let distChart:  ReturnType<typeof initBrushChart> | null = null;
let dateChart:  ReturnType<typeof initBrushChart> | null = null;

// ── render ─────────────────────────────────────────────────────────
function render() {
  if (!hourChart || !delayChart || !distChart || !dateChart) return;
  const { hBg, hFg, dateBg, dateFg, dBg, dFg, xBg, xFg, total } = compute();
  updateBars(hourChart.ctx,  hBg,    hFg);
  updateBars(delayChart.ctx, dBg,    dFg);
  updateBars(distChart.ctx,  xBg,    xFg);
  updateBars(dateChart.ctx,  dateBg, dateFg);
  document.getElementById('cfd-n')!.textContent = total.toLocaleString();
  document.getElementById('cfd-date-label')!.textContent =
    `${DATE_LABELS[state.dateRange[0]]} – ${DATE_LABELS[state.dateRange[1]]}`;
  updateList();
}

function resetFilters() {
  state.ap         = -1;
  state.hourRange  = [0, 23];
  state.dateRange  = [0, 132];
  state.delayRange = [0, 13];
  state.distRange  = [0, 14];
  sortCol = 'n';
  sortDir = -1;
  hourChart?.clear();
  delayChart?.clear();
  distChart?.clear();
  dateChart?.clear();
  document.querySelectorAll('#cfd-ap .cfd-apbtn').forEach(b => b.classList.remove('active'));
  document.querySelector<HTMLElement>('#cfd-ap .cfd-apbtn[data-ap="-1"]')!.classList.add('active');
  render();
}

function initCharts() {
  const isMobile = window.innerWidth <= 640;

  hourChart  = initBrushChart(
    document.getElementById('cfd-hour')  as SVGSVGElement,
    HOUR_LABELS,
    (lo, hi) => { state.hourRange  = [lo, hi]; render(); },
    (_, i) => i % 4 === 0,
  );
  delayChart = initBrushChart(
    document.getElementById('cfd-delay') as SVGSVGElement,
    DELAY_LABELS,
    (lo, hi) => { state.delayRange = [lo, hi]; render(); },
    (_, i) => i % 2 === 0,
  );
  distChart  = initBrushChart(
    document.getElementById('cfd-dist')  as SVGSVGElement,
    DIST_LABELS,
    (lo, hi) => { state.distRange  = [lo, hi]; render(); },
    (_, i) => i % 2 === 0,
  );
  dateChart  = initBrushChart(
    document.getElementById('cfd-date')  as SVGSVGElement,
    DATE_LABELS,
    (lo, hi) => { state.dateRange  = [lo, hi]; render(); },
    (_, i) => i % (isMobile ? 24 : 12) === 0,
    4,
  );
  // Column sort headers
  document.querySelectorAll<HTMLElement>('#cfd-table th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col!;
      if (col === sortCol) {
        sortDir = (sortDir === -1 ? 1 : -1) as 1 | -1;
      } else {
        sortCol = col;
        sortDir = (col === 'route' || col === 'dest') ? 1 : -1;
      }
      render();
    });
  });

  document.getElementById('cfd-reset')!.addEventListener('click', resetFilters);

  render();
}

const cfdEl = document.getElementById('cfd') as HTMLElement;
const ro = new ResizeObserver((entries) => {
  if (entries[0].contentRect.width > 0) { ro.disconnect(); initCharts(); }
});
ro.observe(cfdEl);
if (cfdEl.getBoundingClientRect().width > 0) { ro.disconnect(); initCharts(); }

document.querySelectorAll<HTMLButtonElement>('#cfd-ap .cfd-apbtn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#cfd-ap .cfd-apbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.ap = parseInt(btn.dataset.ap!);
    render();
  });
});
</script>

