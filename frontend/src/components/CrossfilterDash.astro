---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="cfd" data-base={base}>
  <!-- ── filter + count bar ── -->
  <div class="cfd-header">
    <div id="cfd-ap" role="group" aria-label="Filter by airport">
      <button class="cfd-apbtn active" data-ap="-1">All</button>
      <button class="cfd-apbtn iad"    data-ap="0">IAD</button>
      <button class="cfd-apbtn dca"    data-ap="1">DCA</button>
      <button class="cfd-apbtn bwi"    data-ap="2">BWI</button>
    </div>
    <p class="cfd-count"><span id="cfd-n">loading…</span> flights selected</p>
  </div>

  <!-- ── 4 charts: 3 across top, date full-width below ── -->
  <div class="cfd-grid">
    <figure class="cfd-panel">
      <figcaption>Hour of Day <em>— drag to filter</em></figcaption>
      <svg id="cfd-hour"  class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Arrival Delay (minutes) <em>— click to toggle</em></figcaption>
      <svg id="cfd-delay" class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel">
      <figcaption>Distance (miles) <em>— click to toggle</em></figcaption>
      <svg id="cfd-dist"  class="cfd-svg"></svg>
    </figure>
    <figure class="cfd-panel cfd-wide">
      <figcaption>Date <em>— drag to filter</em></figcaption>
      <svg id="cfd-date" class="cfd-svg"></svg>
    </figure>
  </div>

  <!-- ── route list (like the original crossfilter table) ── -->
  <aside id="cfd-totals">
    <span id="cfd-list-count">—</span> routes for the selected airport.
    <span class="cfd-totals-note">Late rate, delay, and fare are decade averages.</span>
  </aside>

  <div id="cfd-list">
    <table id="cfd-table">
      <thead>
        <tr>
          <th class="col-route">Route</th>
          <th class="col-dest">Destination</th>
          <th class="col-flights" title="Total operated flights 2015–2026">Flights</th>
          <th class="col-late">Late rate</th>
          <th class="col-delay">Avg delay</th>
          <th class="col-fare">Avg fare</th>
        </tr>
      </thead>
      <tbody id="cfd-tbody">
        <tr><td colspan="6" class="loading-row">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
import {
  select, scaleLinear, scaleBand, brushX,
  axisBottom, axisLeft, max as d3max,
} from 'd3';
import type { BrushBehavior, ScaleBand, ScaleLinear, Selection } from 'd3';

// ── types ──────────────────────────────────────────────────────────
interface CFData { airports: string[]; rows: number[][]; }
interface RouteProps {
  origin: string; dest: string; dest_city: string;
  late_rate: number; flight_freq: number; mean_delay: number;
  mean_fare: number; mean_distance: number; kmeans: number;
}

// ── load data ──────────────────────────────────────────────────────
const mount = document.getElementById('cfd') as HTMLElement;
const base  = mount.dataset.base ?? '';

const [cfData, routeGeo] = await Promise.all([
  fetch(`${base}/data/crossfilter_data.json`).then(r => r.json()) as Promise<CFData>,
  fetch(`${base}/data/routes.geojson`).then(r => r.json()),
]);
const rows   = cfData.rows;
const routes: RouteProps[] = routeGeo.features.map((f: any) => f.properties);

// Column offsets in each crossfilter row
const DB = 7;   // delay bins db0..db5 → indices 7..12
const XB = 13;  // dist  bins xb0..xb5 → indices 13..18

// ── state ──────────────────────────────────────────────────────────
const state = {
  ap:         -1,
  hourRange:  [0, 23]   as [number, number],
  dateRange:  [0, 132]  as [number, number],
  delayMask:  0x3F,
  distMask:   0x3F,
};

// ── colours ────────────────────────────────────────────────────────
const AP_CODES  = ['IAD', 'DCA', 'BWI'];
const AP_COLORS = ['#4e9af1', '#f97316', '#22c55e'];
const ALL_COLOR = '#a78bfa';
const accent = () => state.ap >= 0 ? AP_COLORS[state.ap] : ALL_COLOR;

// ── crossfilter compute ────────────────────────────────────────────
function compute() {
  const hBg    = new Float64Array(24),  hFg    = new Float64Array(24);
  const dateBg = new Float64Array(133), dateFg = new Float64Array(133);
  const dBg    = new Float64Array(6),   dFg    = new Float64Array(6);
  const xBg    = new Float64Array(6),   xFg    = new Float64Array(6);
  let total = 0;

  for (const r of rows) {
    const o = r[0], yr = r[1], m = r[2], h = r[3];
    if (state.ap >= 0 && o !== state.ap) continue;

    const ymIdx = (yr - 2015) * 12 + (m - 1);

    let dN = 0, xN = 0;
    for (let i = 0; i < 6; i++) {
      if (state.delayMask & (1 << i)) dN += r[DB + i];
      if (state.distMask  & (1 << i)) xN += r[XB + i];
    }

    const pM = ymIdx >= state.dateRange[0] && ymIdx <= state.dateRange[1];
    const pH = h >= state.hourRange[0] && h <= state.hourRange[1];
    const pD = dN > 0;
    const pX = xN > 0;

    const opN = r[DB]+r[DB+1]+r[DB+2]+r[DB+3]+r[DB+4]+r[DB+5];
    hBg[h]       += opN;
    dateBg[ymIdx] += opN;
    for (let i = 0; i < 6; i++) { dBg[i] += r[DB+i]; xBg[i] += r[XB+i]; }

    if (pM && pD && pX) hFg[h]        += dN;
    if (pH && pD && pX) dateFg[ymIdx] += dN;
    if (pM && pH && pX) for (let i = 0; i < 6; i++) dFg[i] += r[DB+i];
    if (pM && pH && pD) for (let i = 0; i < 6; i++) xFg[i] += r[XB+i];
    if (pM && pH && pD && pX) total += dN;
  }
  return { hBg, hFg, dateBg, dateFg, dBg, dFg, xBg, xFg, total };
}

// ── route list ─────────────────────────────────────────────────────
function updateList() {
  const apFilter = state.ap >= 0 ? AP_CODES[state.ap] : null;
  const filtered = apFilter
    ? routes.filter(r => r.origin === apFilter)
    : routes;
  const sorted = [...filtered].sort((a, b) => b.flight_freq - a.flight_freq);

  document.getElementById('cfd-list-count')!.textContent = String(sorted.length);

  const tbody = document.getElementById('cfd-tbody')!;
  tbody.innerHTML = sorted.map(r => {
    const late    = (r.late_rate * 100).toFixed(1);
    const pct     = Math.round(r.late_rate * 100);
    const col     = apFilter ? accent() : (AP_COLORS[AP_CODES.indexOf(r.origin)] ?? ALL_COLOR);
    const city    = r.dest_city || r.dest;
    const fare    = r.mean_fare ? `$${Math.round(r.mean_fare)}` : '—';
    const delay   = r.mean_delay ? `+${Math.round(r.mean_delay)} min` : '—';
    return `
      <tr>
        <td class="col-route"><span class="ap-dot" style="background:${col}"></span>${r.origin} → ${r.dest}</td>
        <td class="col-dest">${city}</td>
        <td class="col-flights">${r.flight_freq.toLocaleString()}</td>
        <td class="col-late">
          <div class="late-bar-wrap">
            <div class="late-bar" style="width:${pct}%;background:${col}"></div>
          </div>
          <span class="late-pct">${late}%</span>
        </td>
        <td class="col-delay">${delay}</td>
        <td class="col-fare">${fare}</td>
      </tr>`;
  }).join('');
}

// ── chart layout ───────────────────────────────────────────────────
const PAD = { t: 6, r: 8, b: 30, l: 40 };

interface ChartContext {
  g:   Selection<SVGGElement, unknown, null, undefined>;
  xSc: ScaleBand<string>;
  ySc: ScaleLinear<number, number>;
  cW:  number; cH: number;
}

function dims(svgEl: SVGSVGElement) {
  const panel = svgEl.closest('figure') as HTMLElement | null;
  const panelW = panel ? panel.getBoundingClientRect().width : 0;
  const W = Math.max(panelW - 28, 200);
  return { W, H: 145, cW: W - PAD.l - PAD.r, cH: 145 - PAD.t - PAD.b };
}

// ── brush chart ────────────────────────────────────────────────────
function initBrushChart(
  svgEl: SVGSVGElement, labels: string[],
  onBrush: (lo: number, hi: number) => void,
  tickStep?: number,
) {
  const svg = select(svgEl);
  const { W, H, cW, cH } = dims(svgEl);
  svg.attr('width', W).attr('height', H);

  const g      = svg.append('g').attr('class', 'bars').attr('transform', `translate(${PAD.l},${PAD.t})`);
  const brushG = svg.append('g').attr('class', 'brush').attr('transform', `translate(${PAD.l},${PAD.t})`);

  const xSc = scaleBand().domain(labels).range([0, cW]).padding(labels.length > 14 ? 0.08 : 0.15);
  const ySc = scaleLinear().range([cH, 0]);

  const step = tickStep ?? (labels.length > 14 ? 4 : 1);
  const tickFn = (ax: ReturnType<typeof axisBottom>) => {
    if (step > 1) ax.tickValues(labels.filter((_, i) => i % step === 0));
    return ax;
  };
  g.append('g').attr('class', 'x-ax').attr('transform', `translate(0,${cH})`)
    .call(tickFn(axisBottom(xSc).tickSize(0)))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '0.9em'); });
  g.append('g').attr('class', 'y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  const brush = brushX<unknown>()
    .extent([[0, 0], [cW, cH]])
    .on('end', (event) => {
      if (!event.selection) { onBrush(0, labels.length - 1); return; }
      const [px0, px1] = event.selection as [number, number];
      const s = xSc.step();
      onBrush(
        Math.max(0, Math.floor(px0 / s)),
        Math.min(labels.length - 1, Math.ceil(px1 / s) - 1),
      );
    });
  brushG.call(brush);
  brushG.select('.selection').attr('fill', 'rgba(160,140,210,0.15)').attr('stroke', 'rgba(167,139,250,0.4)').attr('stroke-width', '1px');
  brushG.select('.overlay').attr('fill', 'transparent');

  return { ctx: { g, xSc, ySc, cW, cH } };
}

// ── toggle chart ───────────────────────────────────────────────────
function initToggleChart(
  svgEl: SVGSVGElement, labels: string[],
  maskKey: 'delayMask' | 'distMask',
) {
  const svg = select(svgEl);
  const { W, H, cW, cH } = dims(svgEl);
  svg.attr('width', W).attr('height', H);

  const g   = svg.append('g').attr('class', 'bars').attr('transform', `translate(${PAD.l},${PAD.t})`);
  const xSc = scaleBand().domain(labels).range([0, cW]).padding(0.25);
  const ySc = scaleLinear().range([cH, 0]);

  g.append('g').attr('class', 'x-ax').attr('transform', `translate(0,${cH})`)
    .call(axisBottom(xSc).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '0.9em'); });
  g.append('g').attr('class', 'y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  return { ctx: { g, xSc, ySc, cW, cH }, maskKey };
}

// ── update bars ────────────────────────────────────────────────────
function updateBars(ctx: ChartContext, bg: Float64Array, fg: Float64Array, maskKey?: 'delayMask' | 'distMask') {
  const { g, xSc, ySc, cW, cH } = ctx;
  const labels = xSc.domain();
  ySc.domain([0, Math.max(d3max(bg) ?? 0, 1)]).nice();

  g.select<SVGGElement>('g.y-ax')
    .call(axisLeft(ySc).ticks(3).tickFormat(v => `${Math.round(+v/1000)}k`))
    .call(a => { a.select('.domain').remove(); a.selectAll('line').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  g.selectAll<SVGLineElement, number>('line.grid')
    .data(ySc.ticks(3)).join('line').attr('class', 'grid')
    .attr('x1', 0).attr('x2', cW)
    .attr('y1', d => ySc(d)).attr('y2', d => ySc(d))
    .attr('stroke', '#1a1d2a').attr('stroke-width', 1).lower();

  type D = { v: number; i: number };
  const bgData: D[] = Array.from(bg, (v, i) => ({ v, i }));
  const fgData: D[] = Array.from(fg, (v, i) => ({ v, i }));
  const col = accent();

  g.selectAll<SVGRectElement, D>('rect.bg')
    .data(bgData, d => String(d.i)).join('rect').attr('class', 'bg')
    .attr('x', d => xSc(labels[d.i])!).attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth()).attr('height', d => cH - ySc(d.v))
    .attr('fill', '#1e2132').style('cursor', maskKey ? 'pointer' : 'default');

  g.selectAll<SVGRectElement, D>('rect.fg')
    .data(fgData, d => String(d.i)).join('rect').attr('class', 'fg')
    .attr('x', d => xSc(labels[d.i])!).attr('y', d => ySc(d.v))
    .attr('width', xSc.bandwidth()).attr('height', d => cH - ySc(d.v))
    .attr('fill', d => maskKey ? ((state[maskKey] & (1 << d.i)) ? col : '#2a2d3a') : col)
    .attr('opacity', 0.88).style('cursor', maskKey ? 'pointer' : 'default');

  if (maskKey) {
    const key = maskKey;
    g.selectAll<SVGRectElement, D>('rect.fg, rect.bg')
      .on('click', (_, d) => { state[key] ^= (1 << d.i); render(); });
  }
}

// ── labels ─────────────────────────────────────────────────────────
const HOUR_LABELS  = Array.from({length: 24}, (_, i) => String(i));
const DELAY_LABELS = ['early','0–14','15–29','30–59','1–2h','2h+'];
const DIST_LABELS  = ['<300','300–','600–','1k–','1.5k–','2.5k+'];

const MN = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DATE_LABELS: string[] = [];
for (let y = 2015; y <= 2026; y++) {
  const end = y === 2026 ? 1 : 12;
  for (let mo = 1; mo <= end; mo++) {
    DATE_LABELS.push(`${MN[mo-1]} '${String(y).slice(2)}`);
  }
}

let hourChart:  ReturnType<typeof initBrushChart>  | null = null;
let dateChart:  ReturnType<typeof initBrushChart>  | null = null;
let delayChart: ReturnType<typeof initToggleChart> | null = null;
let distChart:  ReturnType<typeof initToggleChart> | null = null;

// ── render ─────────────────────────────────────────────────────────
function render() {
  if (!hourChart || !dateChart || !delayChart || !distChart) return;
  const { hBg, hFg, dateBg, dateFg, dBg, dFg, xBg, xFg, total } = compute();
  updateBars(hourChart.ctx,  hBg,    hFg);
  updateBars(dateChart.ctx,  dateBg, dateFg);
  updateBars(delayChart.ctx, dBg,    dFg, delayChart.maskKey);
  updateBars(distChart.ctx,  xBg,    xFg, distChart.maskKey);
  document.getElementById('cfd-n')!.textContent = total.toLocaleString();
  updateList();
}

function initCharts() {
  hourChart  = initBrushChart(
    document.getElementById('cfd-hour')  as SVGSVGElement,
    HOUR_LABELS,
    (lo, hi) => { state.hourRange = [lo, hi]; render(); },
  );
  dateChart  = initBrushChart(
    document.getElementById('cfd-date')  as SVGSVGElement,
    DATE_LABELS,
    (lo, hi) => { state.dateRange = [lo, hi]; render(); },
    12,
  );
  delayChart = initToggleChart(document.getElementById('cfd-delay') as SVGSVGElement, DELAY_LABELS, 'delayMask');
  distChart  = initToggleChart(document.getElementById('cfd-dist')  as SVGSVGElement, DIST_LABELS,  'distMask');
  render();
}

const cfdEl = document.getElementById('cfd') as HTMLElement;
const ro = new ResizeObserver((entries) => {
  if (entries[0].contentRect.width > 0) { ro.disconnect(); initCharts(); }
});
ro.observe(cfdEl);
if (cfdEl.getBoundingClientRect().width > 0) { ro.disconnect(); initCharts(); }

// ── airport buttons ────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('#cfd-ap .cfd-apbtn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#cfd-ap .cfd-apbtn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    state.ap = parseInt(btn.dataset.ap!);
    render();
  });
});
</script>

<style>
  #cfd { margin-top: 1.75rem; }

  /* ── header ── */
  .cfd-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.1rem;
    flex-wrap: wrap;
  }
  #cfd-ap { display: flex; gap: 0.4rem; }
  .cfd-apbtn {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    color: var(--muted);
    border-radius: 6px;
    padding: 0.28rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s;
  }
  .cfd-apbtn.active     { border-color: #a78bfa; color: #a78bfa; }
  .cfd-apbtn.iad.active { border-color: #4e9af1; color: #4e9af1; }
  .cfd-apbtn.dca.active { border-color: #f97316; color: #f97316; }
  .cfd-apbtn.bwi.active { border-color: #22c55e; color: #22c55e; }
  .cfd-count { font-size: 0.8rem; color: var(--muted); margin: 0; }
  #cfd-n { color: #e8e8e8; font-weight: 600; }

  /* ── charts grid: 3 across, date spans full width below ── */
  .cfd-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }
  .cfd-wide { grid-column: 1 / -1; }
  @media (max-width: 768px) { .cfd-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .cfd-grid { grid-template-columns: 1fr; } }

  .cfd-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.85rem 0.85rem 0.5rem;
    margin: 0;
  }
  .cfd-panel figcaption {
    font-size: 0.78rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 0.5rem;
  }
  .cfd-panel figcaption em { font-style: normal; font-weight: 400; color: #555; }
  .cfd-svg { display: block; width: 100%; height: 145px; }
  @media (max-width: 640px) { .cfd-svg { height: 115px; } }

  /* D3 brush */
  :global(.brush .handle) { display: none; }
  :global(.brush .selection) {
    fill: rgba(160,140,210,0.15) !important;
    stroke: rgba(167,139,250,0.4) !important;
    stroke-width: 1px !important;
  }

  /* ── totals line (like original crossfilter aside) ── */
  #cfd-totals {
    margin-top: 1.25rem;
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  #cfd-list-count { color: #e8e8e8; font-weight: 600; }
  .cfd-totals-note { color: #444; font-size: 0.72rem; }

  /* ── route list table ── */
  #cfd-list {
    margin-top: 0.5rem;
    max-height: 420px;
    overflow-y: auto;
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    background: var(--surface);
  }
  #cfd-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }
  #cfd-table thead {
    position: sticky;
    top: 0;
    background: #141620;
    z-index: 1;
  }
  #cfd-table th {
    text-align: left;
    padding: 0.55rem 0.85rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
    border-bottom: 1px solid #2a2d3a;
    white-space: nowrap;
  }
  #cfd-table td {
    padding: 0.48rem 0.85rem;
    border-bottom: 1px solid #1c1f2e;
    color: #ccc;
    vertical-align: middle;
  }
  #cfd-table tbody tr:last-child td { border-bottom: none; }
  #cfd-table tbody tr:hover td { background: #1a1d2e; }

  .col-route { font-weight: 600; color: #e8e8e8; white-space: nowrap; }
  .col-dest  { color: #888; }
  .col-flights { text-align: right; font-variant-numeric: tabular-nums; }
  .col-delay   { text-align: right; font-variant-numeric: tabular-nums; color: #888; }
  .col-fare    { text-align: right; font-variant-numeric: tabular-nums; }

  .ap-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    margin-right: 0.45rem;
    vertical-align: middle;
    flex-shrink: 0;
  }

  /* late rate bar (like crossfilter's visual bar) */
  .col-late {
    min-width: 110px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .late-bar-wrap {
    flex: 1;
    height: 6px;
    background: #1e2132;
    border-radius: 3px;
    overflow: hidden;
    min-width: 40px;
  }
  .late-bar {
    height: 100%;
    border-radius: 3px;
    opacity: 0.7;
  }
  .late-pct {
    font-variant-numeric: tabular-nums;
    color: #aaa;
    white-space: nowrap;
    font-size: 0.75rem;
    min-width: 3.2em;
    text-align: right;
  }

  .loading-row { text-align: center; color: #444; padding: 1.5rem !important; }

  @media (max-width: 640px) {
    #cfd-list { max-height: 320px; }
    .col-delay, .col-fare { display: none; }
    #cfd-table th.col-delay, #cfd-table th.col-fare { display: none; }
  }
</style>
