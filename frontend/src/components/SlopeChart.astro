---
import heatmaps from '@data/heatmaps.json';

type HeatData = { hours: number[]; months: number[]; values: (number | null)[][] };
const data = heatmaps as Record<string, HeatData>;

const AIRPORTS = ['IAD', 'DCA', 'BWI'] as const;
const COLORS: Record<string, string> = { IAD: '#4e9af1', DCA: '#f97316', BWI: '#22c55e' };

const MORNING_HOURS = [6, 7, 8, 9];
const EVENING_HOURS = [18, 19, 20, 21];

// monthIndex: 0=Jan … 11=Dec
const SEASONS: { name: string; months: number[] }[] = [
  { name: 'Winter', months: [11, 0, 1] },
  { name: 'Spring', months: [2, 3, 4] },
  { name: 'Summer', months: [5, 6, 7] },
  { name: 'Fall',   months: [8, 9, 10] },
];

function avg(values: (number | null)[][], hours: number[], months: number[]): number {
  let sum = 0; let count = 0;
  for (const h of hours) {
    for (const mi of months) {
      const v = values[h]?.[mi];
      if (v != null) { sum += v; count++; }
    }
  }
  return count > 0 ? sum / count : 0;
}

// Compute all values to find global y-scale
type SeasonData = {
  season: string;
  airports: { code: string; morning: number; evening: number }[];
};

const seasonData: SeasonData[] = SEASONS.map(({ name, months }) => ({
  season: name,
  airports: AIRPORTS.map(code => ({
    code,
    morning: avg(data[code].values, MORNING_HOURS, months),
    evening: avg(data[code].values, EVENING_HOURS, months),
  })),
}));

const allVals = seasonData.flatMap(s => s.airports.flatMap(a => [a.morning, a.evening]));
const globalMin = Math.min(...allVals);
const globalMax = Math.max(...allVals);

// SVG layout constants
const SVG_W  = 200;
const SVG_H  = 215;
const TOP    = 28;   // title + padding
const BOTTOM = 185;  // y position of axis line (above x labels)
const CHART_H = BOTTOM - TOP;
const X_MORNING = 32;
const X_EVENING = 132;
const GRID_20_RATE = 0.20;

function toY(v: number): number {
  // Map globalMin→BOTTOM, globalMax→TOP
  return TOP + (1 - (v - globalMin) / (globalMax - globalMin)) * CHART_H;
}

const GRID_Y = toY(GRID_20_RATE);
const SHOW_GRID = GRID_20_RATE >= globalMin && GRID_20_RATE <= globalMax;

function pct(v: number): string {
  return Math.round(v * 100) + '%';
}

// Push labels apart (min 12px gap) — operate on evening-side labels
function pushApart(labels: { y: number; text: string; color: string }[], minGap = 12) {
  // Sort by y ascending, then iteratively push apart
  const sorted = [...labels].sort((a, b) => a.y - b.y);
  let changed = true;
  let iters = 0;
  while (changed && iters < 100) {
    changed = false; iters++;
    for (let i = 1; i < sorted.length; i++) {
      const diff = sorted[i].y - sorted[i - 1].y;
      if (diff < minGap) {
        const push = (minGap - diff) / 2;
        sorted[i - 1].y -= push;
        sorted[i].y     += push;
        changed = true;
      }
    }
  }
  return sorted;
}
---

<div class="slope-grid">
  {seasonData.map(({ season, airports }) => {
    // Build label set for evening side
    const rawLabels = airports.map(a => ({
      y: toY(a.evening) + 4,
      text: `${a.code} ${pct(a.evening)}`,
      color: COLORS[a.code],
    }));
    const adjustedLabels = pushApart(rawLabels, 12);
    // Map back by code for lookup
    const labelMap: Record<string, number> = {};
    // rawLabels and adjustedLabels have same elements after sort, match by text
    for (let i = 0; i < rawLabels.length; i++) {
      const raw = rawLabels[i];
      const adj = adjustedLabels.find(l => l.text === raw.text);
      labelMap[raw.text] = adj ? adj.y : raw.y;
    }

    return (
      <div class="slope-panel">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="slope-svg">
          {/* Season title */}
          <text
            x={SVG_W / 2} y={16}
            text-anchor="middle"
            fill="#aaa"
            font-size="11"
            font-weight="600"
          >{season}</text>

          {/* Grid line at 20% */}
          {SHOW_GRID && (
            <>
              <line
                x1={X_MORNING - 8} x2={X_EVENING + 8}
                y1={GRID_Y} y2={GRID_Y}
                stroke="#2a2d3a"
                stroke-width="1"
              />
              <text
                x={X_MORNING - 10} y={GRID_Y + 3.5}
                text-anchor="end"
                fill="#444"
                font-size="7.5"
              >20%</text>
            </>
          )}

          {/* Lines and dots for each airport */}
          {airports.map(a => {
            const x1 = X_MORNING;
            const y1 = toY(a.morning);
            const x2 = X_EVENING;
            const y2 = toY(a.evening);
            return (
              <>
                <line
                  x1={x1} y1={y1} x2={x2} y2={y2}
                  stroke={COLORS[a.code]}
                  stroke-width="2"
                />
                <circle cx={x1} cy={y1} r="4" fill={COLORS[a.code]} stroke="#0e1017" stroke-width="1.5" />
                <circle cx={x2} cy={y2} r="4" fill={COLORS[a.code]} stroke="#0e1017" stroke-width="1.5" />
              </>
            );
          })}

          {/* Right-side labels (adjusted) */}
          {airports.map(a => {
            const labelText = `${a.code} ${pct(a.evening)}`;
            const labelY = labelMap[labelText] ?? (toY(a.evening) + 4);
            return (
              <text
                x={X_EVENING + 8}
                y={labelY}
                fill={COLORS[a.code]}
                font-size="9"
                font-weight="600"
              >{labelText}</text>
            );
          })}

          {/* X axis line */}
          <line
            x1={X_MORNING - 8} x2={X_EVENING + 8}
            y1={BOTTOM} y2={BOTTOM}
            stroke="#2a2d3a"
            stroke-width="1"
          />

          {/* X axis labels — two tspan lines each */}
          <text
            x={X_MORNING}
            y={BOTTOM + 13}
            text-anchor="middle"
            fill="#555"
            font-size="8.5"
          >
            <tspan x={X_MORNING} dy="0">Morning</tspan>
            <tspan x={X_MORNING} dy="11">6–10am</tspan>
          </text>
          <text
            x={X_EVENING}
            y={BOTTOM + 13}
            text-anchor="middle"
            fill="#555"
            font-size="8.5"
          >
            <tspan x={X_EVENING} dy="0">Evening</tspan>
            <tspan x={X_EVENING} dy="11">6–10pm</tspan>
          </text>
        </svg>
      </div>
    );
  })}
</div>

<style>
  .slope-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
  }
  @media (min-width: 900px) {
    .slope-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .slope-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.65rem;
  }
  .slope-svg {
    display: block;
    width: 100%;
  }
</style>
