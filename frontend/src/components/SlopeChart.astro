---
import heatmaps from '@data/heatmaps.json';

type HeatData = { hours: number[]; months: number[]; values: (number | null)[][] };
const data = heatmaps as Record<string, HeatData>;

const AIRPORTS = ['IAD', 'DCA', 'BWI'] as const;
const AP_COLORS: Record<string, string> = { IAD: '#4e9af1', DCA: '#f97316', BWI: '#22c55e' };

const SEASONS = [
  { label: 'Winter', mIdxs: [11, 0, 1] },
  { label: 'Spring', mIdxs: [2, 3, 4] },
  { label: 'Summer', mIdxs: [5, 6, 7] },
  { label: 'Fall',   mIdxs: [8, 9, 10] },
];
const MORNING = [6, 7, 8, 9];
const EVENING = [18, 19, 20, 21];

function avg(ap: string, hours: number[], mIdxs: number[]): number {
  const vals = data[ap].values;
  let sum = 0, n = 0;
  for (const h of hours) {
    for (const mi of mIdxs) {
      const v = vals[h]?.[mi];
      if (v != null) { sum += v; n++; }
    }
  }
  return n > 0 ? sum / n : 0;
}

const seasons = SEASONS.map(s => ({
  label: s.label,
  aps: (AIRPORTS as readonly string[]).map(ap => ({
    ap,
    color: AP_COLORS[ap],
    morning: avg(ap, MORNING, s.mIdxs),
    evening: avg(ap, EVENING, s.mIdxs),
  })),
}));

const allVals = seasons.flatMap(s => s.aps.flatMap(a => [a.morning, a.evening]));
const rawMin  = Math.min(...allVals);
const rawMax  = Math.max(...allVals);
const Y_MIN   = Math.floor((rawMin - 0.015) * 20) / 20;
const Y_MAX   = Math.ceil((rawMax  + 0.015) * 20) / 20;

const SVG_W = 200;
const SVG_H = 215;
const X_M   = 38;
const X_E   = 132;
const Y_TOP = 30;
const Y_BOT = 180;

function toY(v: number): number {
  return Y_BOT - ((v - Y_MIN) / (Y_MAX - Y_MIN)) * (Y_BOT - Y_TOP);
}
function pct(v: number): string { return Math.round(v * 100) + '%'; }

type LabelItem = { ap: string; color: string; evening: number; dotY: number; labelY: number };

function pushApart(items: Omit<LabelItem, 'labelY'>[]): LabelItem[] {
  const sorted = [...items].sort((a, b) => a.dotY - b.dotY);
  const out: LabelItem[] = sorted.map(d => ({ ...d, labelY: d.dotY }));
  for (let i = 1; i < out.length; i++) {
    if (out[i].labelY - out[i - 1].labelY < 13) {
      out[i].labelY = out[i - 1].labelY + 13;
    }
  }
  return out;
}

const REF_Y   = toY(0.20);
const showRef = REF_Y > Y_TOP + 2 && REF_Y < Y_BOT - 2;
---

<div class="slope-wrap">
  {seasons.map(s => {
    const labels = pushApart(s.aps.map(a => ({
      ap: a.ap, color: a.color, evening: a.evening, dotY: toY(a.evening),
    })));
    return (
      <div class="slope-panel">
        <svg viewBox={`0 0 ${SVG_W} ${SVG_H}`} class="slope-svg">

          <text x={SVG_W / 2} y="18" text-anchor="middle" fill="#aaa" font-size="12" font-weight="600">{s.label}</text>

          {showRef && <line x1={X_M - 6} x2={X_E + 6} y1={REF_Y} y2={REF_Y} stroke="#222530" stroke-width="1" />}
          {showRef && <text x={X_M - 8} y={REF_Y + 3.5} text-anchor="end" fill="#333" font-size="8">20%</text>}

          <line x1={X_M} x2={X_M} y1={Y_TOP - 2} y2={Y_BOT + 2} stroke="#1e2130" stroke-width="1" />
          <line x1={X_E} x2={X_E} y1={Y_TOP - 2} y2={Y_BOT + 2} stroke="#1e2130" stroke-width="1" />

          {s.aps.map(a => (
            <line x1={X_M} y1={toY(a.morning)} x2={X_E} y2={toY(a.evening)} stroke={a.color} stroke-width="2" opacity="0.9" />
          ))}

          {s.aps.map(a => (
            <circle cx={X_M} cy={toY(a.morning)} r="4" fill={a.color} stroke="#0e1017" stroke-width="1.5" />
          ))}
          {s.aps.map(a => (
            <circle cx={X_E} cy={toY(a.evening)} r="4" fill={a.color} stroke="#0e1017" stroke-width="1.5" />
          ))}

          {labels.map(item => (
            <>
              {item.labelY !== item.dotY && (
                <line x1={X_E + 6} y1={item.dotY} x2={X_E + 6} y2={item.labelY} stroke={item.color} stroke-width="0.75" opacity="0.35" />
              )}
              <text x={X_E + 10} y={item.labelY + 3.5} fill={item.color} font-size="10">{item.ap} {pct(item.evening)}</text>
            </>
          ))}

          <text x={X_M} y={SVG_H - 13} text-anchor="middle" fill="#555" font-size="9">Morning</text>
          <text x={X_M} y={SVG_H - 3}  text-anchor="middle" fill="#444" font-size="8">6&#x2013;10am</text>
          <text x={X_E} y={SVG_H - 13} text-anchor="middle" fill="#555" font-size="9">Evening</text>
          <text x={X_E} y={SVG_H - 3}  text-anchor="middle" fill="#444" font-size="8">6&#x2013;10pm</text>
        </svg>
      </div>
    );
  })}
</div>

<style>
  .slope-wrap {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  @media (min-width: 900px) {
    .slope-wrap { grid-template-columns: repeat(4, 1fr); }
  }
  .slope-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.6rem 0.5rem 0.4rem;
  }
  .slope-svg { display: block; width: 100%; height: auto; }
</style>
