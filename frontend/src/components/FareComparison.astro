---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="fare-cmp" data-base={base}>
  <div class="fare-grid">
    <figure class="fare-panel">
      <figcaption>Average fare by year</figcaption>
      <svg id="fare-trend" class="fare-svg"></svg>
    </figure>
    <figure class="fare-panel fare-panel-routes">
      <figcaption>Shared destinations — avg fare by departure airport <em>(top 30 by volume)</em></figcaption>
      <div id="fare-routes-wrap">
        <svg id="fare-routes" class="fare-routes-svg"></svg>
      </div>
    </figure>
  </div>
</div>

<script>
import { select, scaleLinear, scalePoint, line as d3line, axisBottom, axisLeft, min as d3min, max as d3max } from 'd3';

interface FareData {
  airports: string[];
  colors: Record<string, string>;
  trend: { years: number[] } & Record<string, (number | null)[]>;
  shared_routes: Array<{
    dest: string; city: string;
    IAD: number; DCA: number; BWI: number;
    n_IAD: number; n_DCA: number; n_BWI: number;
  }>;
}

const mount  = document.getElementById('fare-cmp') as HTMLElement;
const base   = mount.dataset.base ?? '';
const data   = await fetch(`${base}/data/fare_comparison.json`).then(r => r.json()) as FareData;

const AIRPORTS  = data.airports;
const COLORS    = data.colors;

// ── Trend line chart ──────────────────────────────────────────────
function buildTrend() {
  const svgEl = document.getElementById('fare-trend') as SVGSVGElement;
  const wrap  = svgEl.closest('figure') as HTMLElement;
  const W     = Math.max(wrap.getBoundingClientRect().width - 24, 260);
  const H     = 200;
  const pad   = { t: 16, r: 60, b: 32, l: 44 };
  const cW    = W - pad.l - pad.r;
  const cH    = H - pad.t - pad.b;

  const svg = select(svgEl).attr('width', W).attr('height', H);
  const g   = svg.append('g').attr('transform', `translate(${pad.l},${pad.t})`);

  const years = data.trend.years;
  const allFares = AIRPORTS.flatMap(ap =>
    (data.trend[ap] as (number | null)[]).filter((v): v is number => v !== null)
  );

  const xSc = scalePoint<number>().domain(years).range([0, cW]).padding(0.1);
  const ySc = scaleLinear()
    .domain([Math.floor((d3min(allFares) ?? 150) / 50) * 50,
             Math.ceil((d3max(allFares)  ?? 400) / 50) * 50])
    .range([cH, 0]).nice();

  // Grid lines
  g.selectAll('line.grid').data(ySc.ticks(5)).join('line').attr('class', 'grid')
    .attr('x1', 0).attr('x2', cW)
    .attr('y1', d => ySc(d)).attr('y2', d => ySc(d))
    .attr('stroke', '#1a1d2a').attr('stroke-width', 1);

  // Axes
  g.append('g').attr('transform', `translate(0,${cH})`)
    .call(axisBottom(xSc).tickValues(years.filter((_, i) => i % 2 === 0)).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '1.2em'); });

  g.append('g')
    .call(axisLeft(ySc).ticks(5).tickFormat(v => `$${v}`).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  // Lines + end labels
  const lineGen = d3line<{ y: number; v: number }>()
    .x(d => xSc(d.y)!)
    .y(d => ySc(d.v))
    .defined(d => d.v !== null);

  for (const ap of AIRPORTS) {
    const pts = years
      .map((y, i) => ({ y, v: (data.trend[ap] as (number | null)[])[i] as number }))
      .filter(d => d.v !== null);

    g.append('path')
      .datum(pts)
      .attr('fill', 'none')
      .attr('stroke', COLORS[ap])
      .attr('stroke-width', 2)
      .attr('d', lineGen as any);

    // Dot at last point
    const last = pts[pts.length - 1];
    if (last) {
      g.append('circle').attr('cx', xSc(last.y)!).attr('cy', ySc(last.v)).attr('r', 3).attr('fill', COLORS[ap]);
      g.append('text')
        .attr('x', xSc(last.y)! + 7).attr('y', ySc(last.v) + 4)
        .attr('fill', COLORS[ap]).attr('font-size', '10px').attr('font-weight', '600')
        .text(ap);
    }
  }
}

// ── Dumbbell chart ────────────────────────────────────────────────
function buildDumbbell() {
  const svgEl  = document.getElementById('fare-routes') as SVGSVGElement;
  const wrap   = document.getElementById('fare-routes-wrap') as HTMLElement;
  const W      = Math.max(wrap.getBoundingClientRect().width - 4, 260);
  const ROW_H  = 26;
  const routes = data.shared_routes;
  const pad    = { t: 24, r: 16, b: 8, l: 118 };
  const cW     = W - pad.l - pad.r;
  const H      = pad.t + routes.length * ROW_H + pad.b;

  const svg = select(svgEl).attr('width', W).attr('height', H);
  const g   = svg.append('g').attr('transform', `translate(${pad.l},${pad.t})`);

  const allFares = routes.flatMap(r => AIRPORTS.map(ap => r[ap as 'IAD'|'DCA'|'BWI']));
  const xSc = scaleLinear()
    .domain([Math.floor((d3min(allFares) ?? 100) / 50) * 50,
             Math.ceil((d3max(allFares)  ?? 500) / 50) * 50])
    .range([0, cW]).nice();

  // Top axis
  g.append('g')
    .call(axisBottom(xSc).ticks(6).tickFormat(v => `$${v}`).tickSize(-(routes.length * ROW_H)))
    .call(a => {
      a.select('.domain').remove();
      a.selectAll('line').attr('stroke', '#1a1d2a');
      a.selectAll('text').attr('fill', '#444').attr('font-size', '10px').attr('dy', '-0.5em');
    });

  // Rows
  routes.forEach((r, i) => {
    const y     = i * ROW_H + ROW_H / 2;
    const fares = AIRPORTS.map(ap => r[ap as 'IAD'|'DCA'|'BWI']);
    const lo    = Math.min(...fares);
    const hi    = Math.max(...fares);

    // Row background on hover (handled via CSS)
    g.append('rect').attr('class', 'row-bg')
      .attr('x', -pad.l).attr('width', W)
      .attr('y', i * ROW_H).attr('height', ROW_H)
      .attr('fill', 'transparent');

    // City label
    g.append('text')
      .attr('x', -8).attr('y', y + 4)
      .attr('text-anchor', 'end')
      .attr('fill', '#aaa').attr('font-size', '11px')
      .text(r.city);

    // Connecting line lo→hi
    g.append('line')
      .attr('x1', xSc(lo)).attr('x2', xSc(hi))
      .attr('y1', y).attr('y2', y)
      .attr('stroke', '#2a2d3a').attr('stroke-width', 2);

    // Dots per airport
    for (const ap of AIRPORTS) {
      const fare = r[ap as 'IAD'|'DCA'|'BWI'];
      g.append('circle')
        .attr('cx', xSc(fare)).attr('cy', y).attr('r', 5)
        .attr('fill', COLORS[ap]).attr('stroke', '#0e1017').attr('stroke-width', 1.5);

      // Tooltip-style title
      g.append('title').text(`${ap}: $${fare}`);
    }
  });
}

// Init on first layout pass
const ro = new ResizeObserver(entries => {
  if (entries[0].contentRect.width > 0) { ro.disconnect(); buildTrend(); buildDumbbell(); }
});
ro.observe(mount);
if (mount.getBoundingClientRect().width > 0) { ro.disconnect(); buildTrend(); buildDumbbell(); }
</script>

<style>
  #fare-cmp { margin-top: 0; }

  .fare-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1rem;
    align-items: start;
  }
  @media (max-width: 900px) { .fare-grid { grid-template-columns: 1fr; } }

  .fare-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.85rem 0.85rem 0.75rem;
    margin: 0;
  }
  .fare-panel figcaption {
    font-size: 0.78rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 0.6rem;
  }
  .fare-panel figcaption em { font-style: normal; font-weight: 400; color: #555; }

  .fare-svg { display: block; width: 100%; }

  #fare-routes-wrap {
    overflow-y: auto;
    max-height: 780px;
  }
  .fare-routes-svg { display: block; width: 100%; }

  :global(#fare-routes .row-bg:hover) { fill: rgba(255,255,255,0.03) !important; }
</style>
