---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="fare-cmp" data-base={base}>
  <div class="fare-grid">
    <figure class="fare-panel">
      <figcaption>Average domestic fare by year <em>(2015–2026)</em></figcaption>
      <svg id="fare-trend" class="fare-svg"></svg>
    </figure>
    <figure class="fare-panel fare-panel-routes">
      <figcaption>Shared domestic destinations — avg fare by departure airport <em>(52 destinations · gray bar = total flights)</em></figcaption>
      <div id="fare-routes-wrap">
        <svg id="fare-routes" class="fare-routes-svg"></svg>
      </div>
    </figure>
  </div>

  <figure class="fare-panel fare-panel-premium">
    <figcaption>IAD fare premium — how much more you pay vs. the cheapest option <em>(same destination)</em></figcaption>
    <svg id="fare-premium" class="fare-premium-svg"></svg>
  </figure>

  <div id="fare-tooltip" class="fare-tooltip" aria-hidden="true">
    <div class="fare-tt-title"></div>
    <div class="fare-tt-body"></div>
  </div>
</div>

<script>
import { select, scaleLinear, scalePoint, line as d3line, axisBottom, axisLeft, min as d3min, max as d3max } from 'd3';

interface FareData {
  airports: string[];
  colors: Record<string, string>;
  trend: { years: number[] } & Record<string, (number | null)[]>;
  shared_routes: Array<{
    dest: string; city: string;
    IAD: number; DCA: number; BWI: number;
    n_IAD: number; n_DCA: number; n_BWI: number;
  }>;
}

const mount = document.getElementById('fare-cmp') as HTMLElement;
const base  = mount.dataset.base ?? '';
const data  = await fetch(`${base}/data/fare_comparison.json`).then(r => r.json()) as FareData;

const AIRPORTS = data.airports;
const COLORS   = data.colors;

// ── Shared tooltip ────────────────────────────────────────────────
const ttEl    = document.getElementById('fare-tooltip')!;
const ttTitle = ttEl.querySelector<HTMLElement>('.fare-tt-title')!;
const ttBody  = ttEl.querySelector<HTMLElement>('.fare-tt-body')!;

type TtRow = { ap: string; val: number; color: string };

function showTooltip(clientX: number, clientY: number, title: string, rows: TtRow[], footer?: string) {
  ttTitle.textContent = title;
  ttBody.innerHTML = rows.map(r =>
    `<div class="fare-tt-row">
      <span class="fare-tt-dot" style="background:${r.color}"></span>
      <span class="fare-tt-ap">${r.ap}</span>
      <span class="fare-tt-val">$${Math.round(r.val)}</span>
    </div>`
  ).join('') + (footer ? `<div class="fare-tt-footer">${footer}</div>` : '');

  const TT_W = 148;
  let x = clientX + 16;
  let y = clientY - 12;
  if (x + TT_W > window.innerWidth - 8) x = clientX - TT_W - 8;
  if (y < 8) y = 8;

  ttEl.style.left    = x + 'px';
  ttEl.style.top     = y + 'px';
  ttEl.style.opacity = '1';
}

function hideTooltip() { ttEl.style.opacity = '0'; }

// ── Trend line chart ──────────────────────────────────────────────
function buildTrend() {
  const svgEl = document.getElementById('fare-trend') as SVGSVGElement;
  const wrap  = svgEl.closest('figure') as HTMLElement;
  const W     = Math.max(wrap.getBoundingClientRect().width - 24, 260);
  const H     = 200;
  const pad   = { t: 16, r: 60, b: 32, l: 44 };
  const cW    = W - pad.l - pad.r;
  const cH    = H - pad.t - pad.b;

  const svg = select(svgEl).attr('width', W).attr('height', H);
  const g   = svg.append('g').attr('transform', `translate(${pad.l},${pad.t})`);

  const years = data.trend.years;
  const allFares = AIRPORTS.flatMap(ap =>
    (data.trend[ap] as (number | null)[]).filter((v): v is number => v !== null)
  );

  const xSc = scalePoint<number>().domain(years).range([0, cW]).padding(0.1);
  const ySc = scaleLinear()
    .domain([Math.floor((d3min(allFares) ?? 150) / 50) * 50,
             Math.ceil((d3max(allFares)  ?? 400) / 50) * 50])
    .range([cH, 0]).nice();

  // Grid
  g.selectAll('line.grid').data(ySc.ticks(5)).join('line').attr('class', 'grid')
    .attr('x1', 0).attr('x2', cW)
    .attr('y1', d => ySc(d)).attr('y2', d => ySc(d))
    .attr('stroke', '#1a1d2a').attr('stroke-width', 1);

  // Axes
  g.append('g').attr('transform', `translate(0,${cH})`)
    .call(axisBottom(xSc).tickValues(years.filter((_, i) => i % 2 === 0)).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#555').attr('font-size', '10px').attr('dy', '1.2em'); });
  g.append('g')
    .call(axisLeft(ySc).ticks(5).tickFormat(v => `$${v}`).tickSize(0))
    .call(a => { a.select('.domain').remove(); a.selectAll('text').attr('fill', '#444').attr('font-size', '10px'); });

  // Lines
  const lineGen = d3line<{ y: number; v: number }>()
    .x(d => xSc(d.y)!).y(d => ySc(d.v)).defined(d => d.v !== null);

  for (const ap of AIRPORTS) {
    const pts = years
      .map((y, i) => ({ y, v: (data.trend[ap] as (number | null)[])[i] as number }))
      .filter(d => d.v !== null);
    g.append('path').datum(pts)
      .attr('fill', 'none').attr('stroke', COLORS[ap]).attr('stroke-width', 2)
      .attr('d', lineGen as any);
    const last = pts[pts.length - 1];
    if (last) {
      g.append('circle').attr('cx', xSc(last.y)!).attr('cy', ySc(last.v)).attr('r', 3).attr('fill', COLORS[ap]);
      g.append('text')
        .attr('x', xSc(last.y)! + 7).attr('y', ySc(last.v) + 4)
        .attr('fill', COLORS[ap]).attr('font-size', '10px').attr('font-weight', '600')
        .text(ap);
    }
  }

  // ── Cursor group (crosshair + dots) ──────────────────────────────
  const cursorG = svg.append('g').attr('pointer-events', 'none')
    .attr('transform', `translate(${pad.l},${pad.t})`).style('opacity', '0');
  cursorG.append('line').attr('class', 'c-line')
    .attr('y1', 0).attr('y2', cH)
    .attr('stroke', '#666').attr('stroke-width', 1).attr('stroke-dasharray', '3 3');
  const cDots: Record<string, ReturnType<typeof cursorG.append>> = {};
  for (const ap of AIRPORTS) {
    cDots[ap] = cursorG.append('circle').attr('r', 4.5)
      .attr('fill', COLORS[ap]).attr('stroke', '#0e1017').attr('stroke-width', 1.5);
  }

  // Transparent overlay for mouse events
  svg.append('rect')
    .attr('transform', `translate(${pad.l},${pad.t})`)
    .attr('width', cW).attr('height', cH)
    .attr('fill', 'transparent').style('cursor', 'crosshair')
    .on('mousemove', (event: MouseEvent) => {
      const svgRect = svgEl.getBoundingClientRect();
      const mx = event.clientX - svgRect.left - pad.l;

      // Nearest year
      let closest = years[0], minDist = Infinity;
      for (const yr of years) {
        const d = Math.abs((xSc(yr) ?? 0) - mx);
        if (d < minDist) { minDist = d; closest = yr; }
      }

      const cx = xSc(closest)!;
      cursorG.select('line.c-line').attr('x1', cx).attr('x2', cx);

      const rows: TtRow[] = [];
      for (const ap of AIRPORTS) {
        const idx = years.indexOf(closest);
        const val = (data.trend[ap] as (number | null)[])[idx];
        if (val != null) {
          (cDots[ap] as any).attr('cx', cx).attr('cy', ySc(val));
          rows.push({ ap, val, color: COLORS[ap] });
        }
      }
      cursorG.style('opacity', '1');
      showTooltip(event.clientX, event.clientY, String(closest), rows);
    })
    .on('mouseleave', () => { cursorG.style('opacity', '0'); hideTooltip(); });
}

// ── Dumbbell chart ────────────────────────────────────────────────
function buildDumbbell() {
  const svgEl  = document.getElementById('fare-routes') as SVGSVGElement;
  const wrap   = document.getElementById('fare-routes-wrap') as HTMLElement;
  const W      = Math.max(wrap.getBoundingClientRect().width - 4, 260);
  const ROW_H  = 26;
  const routes = data.shared_routes;
  const pad    = { t: 24, r: 16, b: 8, l: 185 };
  const cW     = W - pad.l - pad.r;
  const H      = pad.t + routes.length * ROW_H + pad.b;

  const svg = select(svgEl).attr('width', W).attr('height', H);
  const g   = svg.append('g').attr('transform', `translate(${pad.l},${pad.t})`);

  const allFares = routes.flatMap(r => AIRPORTS.map(ap => r[ap as 'IAD'|'DCA'|'BWI']));
  const xSc = scaleLinear()
    .domain([Math.floor((d3min(allFares) ?? 100) / 50) * 50,
             Math.ceil((d3max(allFares)  ?? 500) / 50) * 50])
    .range([0, cW]).nice();

  const totals   = routes.map(r => r.n_IAD + r.n_DCA + r.n_BWI);
  const maxTotal = Math.max(...totals);
  const volSc    = scaleLinear().domain([0, maxTotal]).range([0, cW]);

  // Top axis
  g.append('g')
    .call(axisBottom(xSc).ticks(6).tickFormat(v => `$${v}`).tickSize(-(routes.length * ROW_H)))
    .call(a => {
      a.select('.domain').remove();
      a.selectAll('line').attr('stroke', '#1a1d2a');
      a.selectAll('text').attr('fill', '#444').attr('font-size', '10px').attr('dy', '-0.5em');
    });

  // Rows
  routes.forEach((r, i) => {
    const y     = i * ROW_H + ROW_H / 2;
    const fares = AIRPORTS.map(ap => r[ap as 'IAD'|'DCA'|'BWI']);
    const lo    = Math.min(...fares);
    const hi    = Math.max(...fares);
    const total = r.n_IAD + r.n_DCA + r.n_BWI;

    // Volume bar — drawn first so it sits behind everything
    g.append('rect')
      .attr('x', 0).attr('y', i * ROW_H)
      .attr('width', volSc(total)).attr('height', ROW_H)
      .attr('fill', 'rgba(255,255,255,0.055)')
      .attr('pointer-events', 'none');

    // Row background — hover highlight + tooltip trigger
    g.append('rect').attr('class', 'row-bg')
      .attr('x', -pad.l).attr('width', W)
      .attr('y', i * ROW_H).attr('height', ROW_H)
      .attr('fill', 'transparent').style('cursor', 'default')
      .on('mousemove', (event: MouseEvent) => {
        showTooltip(event.clientX, event.clientY, r.city, [
          { ap: 'IAD', val: r.IAD, color: COLORS['IAD'] },
          { ap: 'DCA', val: r.DCA, color: COLORS['DCA'] },
          { ap: 'BWI', val: r.BWI, color: COLORS['BWI'] },
        ], `${total.toLocaleString()} flights, 2015–2026`);
        select(event.currentTarget as SVGRectElement).attr('fill', 'rgba(255,255,255,0.04)');
      })
      .on('mouseleave', (event: MouseEvent) => {
        hideTooltip();
        select(event.currentTarget as SVGRectElement).attr('fill', 'transparent');
      });

    // City label
    g.append('text')
      .attr('x', -8).attr('y', y + 4)
      .attr('text-anchor', 'end')
      .attr('fill', '#aaa').attr('font-size', '11px')
      .attr('pointer-events', 'none')
      .text(r.city);

    // Connecting range line
    g.append('line')
      .attr('x1', xSc(lo)).attr('x2', xSc(hi))
      .attr('y1', y).attr('y2', y)
      .attr('stroke', '#2a2d3a').attr('stroke-width', 2)
      .attr('pointer-events', 'none');

    // Dots
    for (const ap of AIRPORTS) {
      g.append('circle')
        .attr('cx', xSc(r[ap as 'IAD'|'DCA'|'BWI'])).attr('cy', y).attr('r', 5)
        .attr('fill', COLORS[ap]).attr('stroke', '#0e1017').attr('stroke-width', 1.5)
        .attr('pointer-events', 'none');
    }
  });
}

// ── IAD fare premium bar chart ────────────────────────────────────
function buildPremium() {
  const svgEl = document.getElementById('fare-premium') as SVGSVGElement;
  const wrap  = svgEl.closest('figure') as HTMLElement;
  const W     = Math.max(wrap.getBoundingClientRect().width - 24, 260);
  const ROW_H = 22;
  const pad   = { t: 20, r: 90, b: 8, l: 185 };
  const cW    = W - pad.l - pad.r;

  // Compute IAD premium per route and sort
  type PremiumRow = { city: string; dest: string; premium: number; cheapestAp: string; cheapestFare: number; iadFare: number };
  const premRows: PremiumRow[] = data.shared_routes.map(r => {
    const fares: [string, number][] = AIRPORTS.map(ap => [ap, r[ap as 'IAD'|'DCA'|'BWI']] as [string, number]);
    const [cheapestAp, cheapestFare] = fares.reduce((a, b) => b[1] < a[1] ? b : a);
    return { city: r.city, dest: r.dest, premium: Math.round(r.IAD - cheapestFare), cheapestAp, cheapestFare, iadFare: r.IAD };
  });
  // Routes where IAD is not cheapest first (descending premium), then IAD-is-cheapest at end
  premRows.sort((a, b) => b.premium - a.premium);

  const H = pad.t + premRows.length * ROW_H + pad.b;
  const maxPremium = Math.max(...premRows.map(r => r.premium), 10);
  const xSc = scaleLinear().domain([0, Math.ceil(maxPremium / 25) * 25]).range([0, cW]).nice();

  const svg = select(svgEl).attr('width', W).attr('height', H);
  const g   = svg.append('g').attr('transform', `translate(${pad.l},${pad.t})`);

  // Top axis
  g.append('g')
    .call(axisBottom(xSc).ticks(5).tickFormat(v => `$${v}`).tickSize(-(premRows.length * ROW_H)))
    .call(a => {
      a.select('.domain').remove();
      a.selectAll('line').attr('stroke', '#1a1d2a');
      a.selectAll('text').attr('fill', '#444').attr('font-size', '10px').attr('dy', '-0.5em');
    });

  premRows.forEach((r, i) => {
    const y       = i * ROW_H + ROW_H / 2;
    const iadCheapest = r.premium <= 0;
    const barW    = iadCheapest ? 4 : xSc(r.premium);
    const barCol  = iadCheapest ? COLORS['IAD'] : COLORS[r.cheapestAp];
    const labelTx = iadCheapest ? 'IAD cheapest' : `$${r.premium} more than ${r.cheapestAp}`;
    const labelCol = iadCheapest ? COLORS['IAD'] : '#555';

    // Row bg + tooltip
    g.append('rect').attr('class', 'row-bg')
      .attr('x', -pad.l).attr('width', W)
      .attr('y', i * ROW_H).attr('height', ROW_H)
      .attr('fill', 'transparent').style('cursor', 'default')
      .on('mousemove', (event: MouseEvent) => {
        showTooltip(event.clientX, event.clientY, r.city, [
          { ap: 'IAD', val: r.iadFare,          color: COLORS['IAD'] },
          { ap: r.cheapestAp, val: r.cheapestFare, color: COLORS[r.cheapestAp] },
        ]);
        select(event.currentTarget as SVGRectElement).attr('fill', 'rgba(255,255,255,0.04)');
      })
      .on('mouseleave', (event: MouseEvent) => {
        hideTooltip();
        select(event.currentTarget as SVGRectElement).attr('fill', 'transparent');
      });

    // City label
    g.append('text')
      .attr('x', -8).attr('y', y + 4)
      .attr('text-anchor', 'end').attr('fill', '#aaa').attr('font-size', '11px')
      .attr('pointer-events', 'none').text(r.city);

    // Bar
    g.append('rect')
      .attr('x', 0).attr('y', i * ROW_H + 6)
      .attr('width', barW).attr('height', ROW_H - 12)
      .attr('rx', 2).attr('fill', barCol).attr('opacity', 0.75)
      .attr('pointer-events', 'none');

    // Amount label
    g.append('text')
      .attr('x', barW + 6).attr('y', y + 4)
      .attr('fill', labelCol).attr('font-size', '10px')
      .attr('pointer-events', 'none').text(labelTx);
  });
}

// Init
const ro = new ResizeObserver(entries => {
  if (entries[0].contentRect.width > 0) { ro.disconnect(); buildTrend(); buildDumbbell(); buildPremium(); }
});
ro.observe(mount);
if (mount.getBoundingClientRect().width > 0) { ro.disconnect(); buildTrend(); buildDumbbell(); buildPremium(); }
</script>

<style>
  #fare-cmp { margin-top: 0; }

  .fare-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 1rem;
    align-items: start;
  }
  @media (max-width: 900px) { .fare-grid { grid-template-columns: 1fr; } }

  .fare-panel {
    background: var(--surface);
    border: 1px solid #2a2d3a;
    border-radius: 10px;
    padding: 0.85rem 0.85rem 0.75rem;
    margin: 0;
  }
  .fare-panel figcaption {
    font-size: 0.78rem;
    font-weight: 600;
    color: #aaa;
    margin-bottom: 0.6rem;
  }
  .fare-panel figcaption em { font-style: normal; font-weight: 400; color: #555; }

  .fare-svg { display: block; width: 100%; }

  #fare-routes-wrap { overflow-y: auto; max-height: 680px; }
  .fare-routes-svg  { display: block; width: 100%; }

  .fare-panel-premium {
    margin-top: 1rem;
  }
  .fare-premium-svg { display: block; width: 100%; }

  /* Tooltip */
  .fare-tooltip {
    position: fixed;
    background: #141620;
    border: 1px solid #2a2d3a;
    border-radius: 8px;
    padding: 0.55rem 0.75rem 0.6rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.08s;
    z-index: 200;
    min-width: 130px;
  }
  .fare-tt-title {
    font-size: 0.72rem;
    font-weight: 600;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }
  .fare-tt-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.12rem 0;
  }
  .fare-tt-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .fare-tt-ap {
    font-size: 0.75rem;
    font-weight: 600;
    color: #ccc;
    width: 2.4em;
  }
  .fare-tt-val {
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: #e8e8e8;
    margin-left: auto;
  }
  .fare-tt-footer {
    font-size: 0.68rem;
    color: #555;
    margin-top: 0.35rem;
    padding-top: 0.3rem;
    border-top: 1px solid #2a2d3a;
  }
</style>
