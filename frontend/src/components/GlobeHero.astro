---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="globe-hero">
  <div id="globe-mount" data-base={base}></div>
  <div class="overlay">
    <h1>Three DMV Airports</h1>
    <p class="tagline">2.8 million flights. Ten years of delays, routes, and patterns.</p>
    <p class="scroll-hint">scroll to explore ↓</p>
  </div>
</div>

<script>
import Globe, { type GlobeInstance } from 'globe.gl';
import type { Feature, FeatureCollection, LineString } from 'geojson';

const mount = document.getElementById('globe-mount') as HTMLElement;
const base  = mount.dataset.base ?? '';

// ── colour helpers ──────────────────────────────────────────────
function lerp(a: number, b: number, t: number) {
  return Math.round(a + (b - a) * t);
}
function lateRateColor(rate: number, alpha = 0.85): string {
  const t = Math.min(rate / 0.38, 1);
  return `rgba(${lerp(34,239,t)},${lerp(197,68,t)},${lerp(94,68,t)},${alpha})`;
}

// ── arc data types ───────────────────────────────────────────────
interface DomArc {
  startLat: number; startLng: number;
  endLat: number;   endLng: number;
  late_rate: number; label: string;
}
interface IntlArc {
  startLat: number; startLng: number;
  endLat: number;   endLng: number;
  paxFrac: number;  label: string;
}
interface IntlRoute {
  origin: string; dest: string;
  dest_city: string;
  total_passengers: number;
  o_lat: number; o_lon: number;
  d_lat: number; d_lon: number;
}

// ── init globes ──────────────────────────────────────────────────
const domGlobe: GlobeInstance  = new Globe(mount)
  .width(mount.clientWidth)
  .height(mount.clientHeight)
  .backgroundColor('#0f1117')
  .globeImageUrl('//unpkg.com/three-globe/example/img/earth-night.jpg')
  .atmosphereColor('#4e9af1')
  .atmosphereAltitude(0.12)
  .pointOfView({ lat: 38.95, lng: -50, altitude: 1.8 }, 0);

const intlGlobe: GlobeInstance = new Globe(mount)
  .width(mount.clientWidth)
  .height(mount.clientHeight)
  .backgroundColor('rgba(0,0,0,0)')
  .globeImageUrl('')
  .showAtmosphere(false)
  .pointOfView({ lat: 38.95, lng: -50, altitude: 1.8 }, 0);

// ── load data ───────────────────────────────────────────────────
const [domRes, intlRes] = await Promise.all([
  fetch(`${base}/data/routes.geojson`),
  fetch(`${base}/data/intl_routes.json`),
]);
const domGeo: FeatureCollection  = await domRes.json();
const intlRoutes: IntlRoute[]    = await intlRes.json();

// ── build arc arrays ─────────────────────────────────────────────
const domArcs: DomArc[] = domGeo.features.map((f: Feature) => {
  const coords = (f.geometry as LineString).coordinates;
  const p      = f.properties as Record<string, number & string>;
  return {
    startLat: coords[0][1], startLng: coords[0][0],
    endLat:   coords[1][1], endLng:   coords[1][0],
    late_rate: p.late_rate,
    label: `${p.origin} → ${p.dest}`,
  };
});

const maxPax = Math.max(...intlRoutes.map(r => r.total_passengers));
const intlArcs: IntlArc[] = intlRoutes.map(r => ({
  startLat: r.o_lat, startLng: r.o_lon,
  endLat:   r.d_lat, endLng:   r.d_lon,
  paxFrac:  r.total_passengers / maxPax,
  label: `${r.origin} → ${r.dest} (${r.dest_city})`,
}));

// ── domestic layer ───────────────────────────────────────────────
domGlobe
  .arcsData(domArcs)
  .arcStartLat('startLat').arcStartLng('startLng')
  .arcEndLat('endLat').arcEndLng('endLng')
  .arcColor((d: object) => {
    const { late_rate } = d as DomArc;
    return [lateRateColor(late_rate, 0.25), lateRateColor(late_rate, 0.9)];
  })
  .arcAltitude(0.12)
  .arcStroke(0.4)
  .arcDashLength(0.5)
  .arcDashGap(0.5)
  .arcDashAnimateTime(3000);

// ── international layer ───────────────────────────────────────────
intlGlobe
  .arcsData(intlArcs)
  .arcStartLat('startLat').arcStartLng('startLng')
  .arcEndLat('endLat').arcEndLng('endLng')
  .arcColor((d: object) => {
    const alpha = 0.15 + (d as IntlArc).paxFrac * 0.45;
    return [`rgba(78,154,241,${alpha * 0.3})`, `rgba(78,154,241,${alpha})`];
  })
  .arcAltitude((d: object) => 0.25 + (d as IntlArc).paxFrac * 0.25)
  .arcStroke((d: object) => 0.3 + (d as IntlArc).paxFrac * 1.2)
  .arcDashLength(0.4)
  .arcDashGap(0.6)
  .arcDashAnimateTime(5000);

// ── sync camera ───────────────────────────────────────────────────
domGlobe.controls().addEventListener('change', () => {
  intlGlobe.pointOfView(domGlobe.pointOfView());
});
intlGlobe.controls().addEventListener('change', () => {
  domGlobe.pointOfView(intlGlobe.pointOfView());
});

// ── auto-rotate ───────────────────────────────────────────────────
domGlobe.controls().autoRotate      = true;
domGlobe.controls().autoRotateSpeed = 0.4;
intlGlobe.controls().autoRotate      = true;
intlGlobe.controls().autoRotateSpeed = 0.4;

// ── resize ────────────────────────────────────────────────────────
window.addEventListener('resize', () => {
  domGlobe.width(mount.clientWidth).height(mount.clientHeight);
  intlGlobe.width(mount.clientWidth).height(mount.clientHeight);
});
</script>

<style>
  #globe-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #0f1117;
  }
  #globe-mount {
    position: absolute;
    inset: 0;
  }
  #globe-mount :global(canvas) {
    position: absolute;
    top: 0;
    left: 0;
  }
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
    padding: 2rem;
    background: radial-gradient(ellipse at center, rgba(15,17,23,0.45) 0%, transparent 70%);
  }
  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.8);
  }
  .tagline {
    font-size: clamp(0.95rem, 2.2vw, 1.15rem);
    color: #999;
    margin-bottom: 0;
    text-shadow: 0 1px 8px rgba(0,0,0,0.8);
  }
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.06em;
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.35; }
    50%       { opacity: 1; }
  }
</style>
