---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div id="globe-hero">
  <div id="globe-mount" data-base={base}></div>
  <div class="overlay">
    <h1>Flying out of the DMV</h1>
    <p class="tagline">2.8 million flights. What ten years of data says about the airports that connect the capital to the world.</p>
  </div>

  <div id="globe-bottom">
    <div id="globe-filters" aria-label="Filter by airport">
      <button class="gf-btn active" data-filter="all">All</button>
      <button class="gf-btn iad"   data-filter="IAD">IAD</button>
      <button class="gf-btn dca"   data-filter="DCA">DCA</button>
      <button class="gf-btn bwi"   data-filter="BWI">BWI</button>
    </div>
    <p class="scroll-hint">scroll to explore ↓</p>
  </div>
</div>

<script>
import Globe, { type GlobeInstance } from 'globe.gl';
import type { Feature, FeatureCollection, LineString } from 'geojson';

const mount = document.getElementById('globe-mount') as HTMLElement;
const base  = mount.dataset.base ?? '';

// ── airport colours (IAD=blue, DCA=orange, BWI=green) ───────────
const AP_COLOR: Record<string, string> = {
  IAD: '78,154,241',
  DCA: '249,115,22',
  BWI: '34,197,94',
};
function apColor(origin: string, alpha: number) {
  const rgb = AP_COLOR[origin] ?? '255,255,255';
  return `rgba(${rgb},${alpha})`;
}

// ── unified arc type ─────────────────────────────────────────────
interface Arc {
  startLat: number; startLng: number;
  endLat:   number; endLng:   number;
  kind:      'dom' | 'intl';
  origin:    string;
  paxFrac:   number;
  isReturn:  boolean;
  label:     string;
}
interface IntlRoute {
  origin: string; dest: string;
  dest_city: string;
  total_passengers: number;
  o_lat: number; o_lon: number;
  d_lat: number; d_lon: number;
}

// ── load data ───────────────────────────────────────────────────
const [domRes, intlRes] = await Promise.all([
  fetch(`${base}/data/routes.geojson`),
  fetch(`${base}/data/intl_routes.json`),
]);
const domGeo: FeatureCollection = await domRes.json();
const intlRoutes: IntlRoute[]   = await intlRes.json();

// ── build unified arc array ──────────────────────────────────────
const domArcs: Arc[] = domGeo.features.flatMap((f: Feature) => {
  const coords = (f.geometry as LineString).coordinates;
  const p      = f.properties as Record<string, number & string>;
  const city   = p.dest_city ? ` (${p.dest_city})` : '';
  return [
    {
      startLat: coords[0][1], startLng: coords[0][0],
      endLat:   coords[1][1], endLng:   coords[1][0],
      kind: 'dom' as const, origin: p.origin, paxFrac: 0, isReturn: false,
      label: `${p.origin} → ${p.dest}${city}`,
    },
    {
      startLat: coords[1][1], startLng: coords[1][0],
      endLat:   coords[0][1], endLng:   coords[0][0],
      kind: 'dom' as const, origin: p.origin, paxFrac: 0, isReturn: true,
      label: `${p.dest}${city} → ${p.origin}`,
    },
  ];
});

const maxPax = Math.max(...intlRoutes.map(r => r.total_passengers));
const intlArcs: Arc[] = intlRoutes.flatMap(r => {
  const paxFrac = r.total_passengers / maxPax;
  return [
    {
      startLat: r.o_lat, startLng: r.o_lon,
      endLat:   r.d_lat, endLng:   r.d_lon,
      kind: 'intl' as const, origin: r.origin, paxFrac, isReturn: false,
      label: `${r.origin} → ${r.dest} (${r.dest_city})`,
    },
    {
      startLat: r.d_lat, startLng: r.d_lon,
      endLat:   r.o_lat, endLng:   r.o_lon,
      kind: 'intl' as const, origin: r.origin, paxFrac, isReturn: true,
      label: `${r.dest} (${r.dest_city}) → ${r.origin}`,
    },
  ];
});

const allArcs: Arc[] = [...domArcs, ...intlArcs];

// ── single globe instance ────────────────────────────────────────
const globe: GlobeInstance = new Globe(mount)
  .width(mount.clientWidth)
  .height(mount.clientHeight)
  .backgroundColor('#0f1117')
  .globeImageUrl(`${base}/earth-night.jpg`)
  .atmosphereColor('#4e9af1')
  .atmosphereAltitude(0.12)
  .pointOfView({ lat: 38.95, lng: -50, altitude: 1.8 }, 0)
  .arcsData(allArcs)
  .arcStartLat('startLat').arcStartLng('startLng')
  .arcEndLat('endLat').arcEndLng('endLng')
  .arcColor((d: object) => {
    const { origin, kind, paxFrac } = d as Arc;
    if (kind === 'dom') {
      return [apColor(origin, 0.55), apColor(origin, 0.9)];
    }
    const a = 0.2 + paxFrac * 0.55;
    return [apColor(origin, a * 0.35), apColor(origin, a)];
  })
  .arcAltitude((d: object) => {
    const arc = d as Arc;
    return arc.kind === 'dom' ? 0.12 : 0.25 + arc.paxFrac * 0.25;
  })
  .arcStroke((d: object) => {
    const arc = d as Arc;
    return arc.kind === 'dom' ? 0.8 : 0.5 + arc.paxFrac * 1.5;
  })
  .arcDashLength(0.3)
  .arcDashGap(1.2)
  .arcDashInitialGap((d: object) => (d as Arc).isReturn ? 0.5 : 0)
  .arcDashAnimateTime((d: object) => (d as Arc).kind === 'dom' ? 4000 : 6000)
  .arcLabel((d: object) => (d as Arc).label);

// ── controls ─────────────────────────────────────────────────────
globe.controls().autoRotate      = true;
globe.controls().autoRotateSpeed = 0.4;
globe.controls().enableZoom      = false;

// pause rotation, enable zoom, and fade overlay when mouse is over the sphere
const overlay = document.querySelector('#globe-hero .overlay') as HTMLElement;
let filterActive = false;

mount.addEventListener('mousemove', (e: MouseEvent) => {
  const rect    = mount.getBoundingClientRect();
  const dx      = e.clientX - rect.left  - rect.width  / 2;
  const dy      = e.clientY - rect.top   - rect.height / 2;
  const r       = Math.min(rect.width, rect.height) * 0.38;
  const onGlobe = dx * dx + dy * dy < r * r;
  globe.controls().autoRotate = !onGlobe;
  globe.controls().enableZoom = onGlobe;
  if (!filterActive) overlay.style.opacity = onGlobe ? '0' : '1';
});
mount.addEventListener('mouseleave', () => {
  globe.controls().autoRotate = true;
  globe.controls().enableZoom = false;
  if (!filterActive) overlay.style.opacity = '1';
});

// ── resize ────────────────────────────────────────────────────────
window.addEventListener('resize', () => {
  globe.width(mount.clientWidth).height(mount.clientHeight);
});

// ── airport filter ────────────────────────────────────────────────
const filterBtns = document.querySelectorAll<HTMLButtonElement>('#globe-filters .gf-btn');
filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const f = btn.dataset.filter!;
    filterActive = f !== 'all';
    overlay.style.opacity = filterActive ? '0' : '1';
    globe.arcsData(f === 'all' ? allArcs : allArcs.filter(a => (a as Arc).origin === f));
  });
});
</script>

<style>
  #globe-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background: #0f1117;
  }
  @media (max-width: 640px) {
    #globe-hero { height: 75vh; }
  }

  /* globe.gl tooltip — must sit above the .overlay div */
  #globe-hero :global(.float-tooltip-kap) {
    z-index: 50 !important;
    background: rgba(15, 17, 23, 0.9) !important;
    border: 1px solid #2a2d3a !important;
    border-radius: 6px !important;
    color: #e8e8e8 !important;
    font-size: 0.75rem !important;
    padding: 0.35rem 0.65rem !important;
    white-space: nowrap !important;
  }
  #globe-mount {
    position: absolute;
    inset: 0;
  }
  #globe-mount :global(canvas) {
    position: absolute;
    top: 0;
    left: 0;
  }
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
    padding: 2rem;
    background: radial-gradient(ellipse at center, rgba(15,17,23,0.45) 0%, transparent 70%);
    transition: opacity 0.4s ease;
  }
  h1 {
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    text-shadow: 0 2px 20px rgba(0,0,0,0.8);
  }
  .tagline {
    font-size: clamp(0.95rem, 2.2vw, 1.15rem);
    color: #999;
    margin-bottom: 0;
    text-shadow: 0 1px 8px rgba(0,0,0,0.8);
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.35; }
    50%       { opacity: 1; }
  }

  #globe-bottom {
    position: absolute;
    bottom: 1.25rem;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    z-index: 10;
    pointer-events: none;
  }
  #globe-filters {
    display: flex;
    gap: 0.4rem;
    pointer-events: auto;
  }
  .scroll-hint {
    font-size: 0.8rem;
    color: #555;
    letter-spacing: 0.06em;
    animation: pulse 2.5s ease-in-out infinite;
    margin: 0;
  }
  .gf-btn {
    background: rgba(15,17,23,0.72);
    border: 1px solid #2a2d3a;
    color: #888;
    border-radius: 6px;
    padding: 0.28rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    backdrop-filter: blur(6px);
    transition: border-color 0.15s, color 0.15s;
  }
  .gf-btn.active           { color: #e8e8e8; border-color: #555; }
  .gf-btn.iad.active       { color: #4e9af1; border-color: #4e9af1; }
  .gf-btn.dca.active       { color: #f97316; border-color: #f97316; }
  .gf-btn.bwi.active       { color: #22c55e; border-color: #22c55e; }

  @media (max-width: 640px) {
    #globe-bottom { bottom: 1rem; gap: 0.5rem; }
    .gf-btn { font-size: 0.68rem; padding: 0.22rem 0.55rem; }
  }
</style>
